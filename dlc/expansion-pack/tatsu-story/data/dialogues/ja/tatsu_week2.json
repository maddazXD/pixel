{
  "dialogues": [
    {
      "character": "player",
      "hideCharacter": true,
      "text": "──開業して2週目の朝。\nポストに無言で差し込まれた請求書の束を見て、俺は目眩がした。"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（電気代、水道代、家賃...やばい、金がない...）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "triggerWeeklySettlement": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（所持金は残り少ない…。客は未だにタツ姐だけ。）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（でも、利子の猶予があるだけマシか...タツ姐には感謝しないと。）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（……って、感謝する相手が闇金ってどうなんだ...）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "おう。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "タツ姐さん！来てくれたんですね！",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "...まぁ、確かに効いたからな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "先週の施術の後、肩が軽くなった気がする。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "本当ですか！それは良かった！",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "調子に乗るなよ。借金は借金だからな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "わ、わかってます...。",
      "hideCharacter": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（でも、効果を認めてくれたのは嬉しいな...）"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "おかげで麻雀で3半荘打てたからな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "それはすごいですね！",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "で、今日はどうすんだ？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "今日は背中と腰を中心に施術しようと思います。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "背中と腰か。確かに、そこも凝ってんだよな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "うつ伏せの姿勢で施術させていただきます。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "うつ伏せ？まぁ、そういうもんか。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "はい。背中から腰にかけて、しっかりほぐしていきますね。",
      "hideCharacter": true
    },
    {
      "id": "choice_massage2",
      "character": "player",
      "expression": "normal",
      "text": "背中と腰の状態を確認してもいいですか？",
      "hideCharacter": true,
      "choices": [
        {
          "label": "背筋の張りを確認する",
          "trustDelta": 2,
          "developDelta": 0,
          "next": "normal_path"
        },
        {
          "label": "腰からヒップのラインを撫でて探る",
          "trustDelta": 0,
          "developDelta": 1,
          "next": "hip_path"
        },
        {
          "label": "太ももの内側までゆっくりと…",
          "trustDelta": 0,
          "developDelta": 2,
          "next": "inner_path"
        }
      ]
    },
    {
      "id": "normal_path",
      "character": "player",
      "expression": "normal",
      "text": "背筋がかなり張ってますね。深層筋をゆっくり緩めていきます。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…まぁ、真面目にやってるうちは許す。",
      "characterImage": "tatsu/tatsu.png",
      "next": "change_clothes"
    },
    {
      "id": "hip_path",
      "character": "player",
      "expression": "normal",
      "text": "では…腰からヒップのラインに沿って確認しますね。",
      "hideCharacter": true
    },
    {
      "character": "",
      "expression": "normal",
      "text": "（ゆっくりと撫でると、張った筋肉が熱を帯びて反応してくる…）",
      "cutInImage": "tatsu_butt_check"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（うわっ...すごい弾力...H90だけあって...）",
      "hideCharacter": true,
      "cutInImage": "tatsu_butt_check"
    },
    {
      "character": "タツ姐",
      "expression": "embarrassed",
      "text": "ん…っ…おい、妙な触り方すんな。",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_butt_check"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "す、すみません！大臀筋の張りを確認してただけで…",
      "hideCharacter": true,
      "next": "change_clothes"
    },
    {
      "id": "inner_path",
      "character": "player",
      "expression": "normal",
      "text": "…失礼します。太ももの内側まで、流れを確認します。",
      "hideCharacter": true
    },
    {
      "character": "",
      "expression": "normal",
      "text": "（太ももの付け根を軽く触れると…）",
      "cutInImage": "tatsu_inner_thigh"
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "っ…！お、おい…そこは…",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_inner_thigh"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "リンパの流れを確認してるだけですので…",
      "hideCharacter": true,
      "cutInImage": "tatsu_inner_thigh"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（…ほんの少し熱い…？）",
      "hideCharacter": true,
      "cutInImage": "tatsu_inner_thigh"
    },
    {
      "character": "タツ姐",
      "expression": "embarrassed",
      "text": "……変な意味で反応したんじゃねぇからな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "alert",
      "text": "も、もちろんです！",
      "hideCharacter": true,
      "next": "change_clothes"
    },
    {
      "id": "change_clothes",
      "character": "player",
      "expression": "normal",
      "text": "その前に、施術用のウェアにお着替えをお願いします。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "……またあの布切れかよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…ったく、マジで風邪ひくぞこれ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "",
      "expression": "normal",
      "text": "（タツ姐がしぶしぶ着替え始める…）",
      "cutInImage": "tatsu_changing"
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "見んなって言ってんだろ、コラ。",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_changing"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（でも目が勝手に…やば…）",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "着替えたぞ。変なとこ見んじゃねぇぞ。",
      "characterImage": "tatsu/tatsu.png",
      "outfit": "micro_bikini"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（やっぱりすごいプロポーションだな...）",
      "hideCharacter": true
    },
    {
      "id": "massage_start",
      "character": "player",
      "expression": "normal",
      "text": "それでは、引き続き施術していきますね。"
    }
  ]
}
