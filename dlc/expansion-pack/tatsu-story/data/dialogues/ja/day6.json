    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "いやもっとやばくないかそれ…。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "冗談ですよ！ ちゃんと普通のウェアがありますから。あの施術着は女性のお客様専用です。"
