    {
      "character": "タツ姐",
      "expression": "closemouth",
      "text": "…ったく、冗談きついんだよ。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "で、今日の調子はどうですか？"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "……実はよ、最近あんまり眠れなくてな。",
      "outfit": "suit"
    },
    {
      "character": "player",
