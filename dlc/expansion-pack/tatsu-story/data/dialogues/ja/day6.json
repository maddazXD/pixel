    {
      "character": "タツ姐",
      "expression": "closeeyes",
      "text": "ああ。お前の施術、悪くねぇよ。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "ありがとうございます！ おかげさまで、紹介していただいた方々もリピートしてくれてます。"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "部下も「姐さんの紹介、マジで良かったっす」って言ってたぞ。感謝しろよ。",
