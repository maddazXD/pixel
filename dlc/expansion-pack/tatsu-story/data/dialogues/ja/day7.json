      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "え、俺が？"
    },
    {
      "character": "player",
      "text": "（タツ姐の夢に俺が出てくるとか…最高じゃん。）"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "夢の中で、俺は何をしてるんですか？"
