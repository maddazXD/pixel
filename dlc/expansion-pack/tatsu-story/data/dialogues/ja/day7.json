    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "下着が…？"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…朝起きると、妙に…湿ってたり、するんだよ…。",
      "outfit": "suit"
