{
  "dialogues": [
    {
      "character": "player",
      "hideCharacter": true,
      "text": "──3週目の朝。\nタツ姐との施術も3週目に入った。"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（借金返済のプレッシャーはあるけど、タツ姐は週1で来てくれてる…）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（利子猶予の恩恵は大きい。でも、いつまで続くか…）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "triggerWeeklySettlement": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（…やっぱり、固定費が重い。客が増えないと返済なんて無理だ…）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（でも、タツ姐の施術だけは続けないと…利子猶予が切れたら終わりだ。）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "おう。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "タツ姐さん！今日もありがとうございます。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "で、借金の返済はどうなってんだ？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "alert",
      "text": "そ、それが…まだ客が増えなくて…",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "客、増えてねぇのか？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "は、はい…なかなか厳しくて…",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "利子猶予してやってんだから、ちゃんと結果出せよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "alert",
      "text": "す、すみません！頑張ります！",
      "hideCharacter": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（やばい…タツ姐、機嫌悪い…）"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…まぁ、お前の施術のおかげで仕事は捗ってるけどな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "本当ですか！それは良かった！",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "先週、組員の管理で3時間立ちっぱなしだったんだけどよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "お前の施術受けた後だったから、肩が持ったんだよな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "それは何よりです。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "毎日ストレスばっかりでな…取り立ても、組員の管理も…。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "社長って立場は楽じゃねぇんだよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "タツ姐の仕事、大変そうですね…。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "ま、それが仕事だからな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "今日はどのあたりが気になりますか？",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "肩と背中だな。特に肩甲骨のあたりがガチガチでよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "肩甲骨周りですね。それなら、今日は胸筋もほぐした方がいいかもしれません。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "胸筋？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "はい。肩甲骨と胸筋は連動してるんです。胸筋が凝ってると肩甲骨の動きも悪くなります。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…ふーん。まぁ、医学的な理由があるってんなら。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "id": "choice_massage3",
      "character": "player",
      "expression": "normal",
      "text": "それでは施術の準備をさせていただきますね。",
      "hideCharacter": true,
      "choices": [
        {
          "label": "タツ姐の仕事、本当に大変そうですね",
          "trustDelta": 2,
          "developDelta": 0,
          "next": "sympathy_path"
        },
        {
          "label": "そんなでかいおっぱいだったら、相当凝ってますよね",
          "trustDelta": 1,
          "developDelta": 2,
          "next": "kcup_path"
        },
        {
          "label": "直接触って確認してもいいですか？",
          "trustDelta": 0,
          "developDelta": 2,
          "next": "chest_check_path"
        }
      ]
    },
    {
      "id": "sympathy_path",
      "character": "player",
      "expression": "normal",
      "text": "社長として毎日プレッシャーの中で働いて…本当に大変そうですよね。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…ま、それが仕事だからな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "（常に眉間に皺を寄せてるからわかりづらいけど、意外と若いんだよな…）",
      "hideCharacter": true
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "その若さで社長って、本当にすごいですね。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…まぁ、…そう言われると悪い気はしねぇな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "少しでもリラックスしていただけるよう、しっかり施術させていただきます。",
      "hideCharacter": true,
      "next": "change_clothes"
    },
    {
      "id": "chest_check_path",
      "character": "player",
      "expression": "normal",
      "text": "直接触って、胸筋の張りを確認してもいいですか？",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "…おい、どこ触ろうとしてんだ？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "大胸筋の張りを確認します。肩こりの原因はここにあることが多いので。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…まぁ、そういうことなら。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "",
      "expression": "normal",
      "text": "（鎖骨の下あたりを軽く押さえる。）",
      "cutInImage": "tatsu_chest_check"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…ん。確かに…張ってるな。",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_chest_check"
    },
    {
      "character": "",
      "expression": "normal",
      "text": "さらに下の方を押さえようとする…が、指が少し滑って——",
      "cutInImage": "tatsu_chest_check"
    },
    {
      "character": "タツ姐",
      "expression": "embarrassed",
      "text": "んっ…！お、おい…っ、どこ触ってんだ…！",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "alert",
      "text": "す、すみません！手が滑って…！"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "ったく…わざとじゃねぇんだろうな？"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "絶対違います！施術のためです！"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…やるんなら、きっちりやってちゃんと効果出せよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "は、はい！しっかりやらせていただきます。",
      "hideCharacter": true,
      "next": "change_clothes"
    },
    {
      "id": "kcup_path",
      "character": "player",
      "expression": "normal",
      "text": "そんなでかいおっぱいだったら、相当凝ってますよね。"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "……おい、今なんて言った？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "い、いえ！その…医学的に！胸が大きい人ほど、胸筋に負担が…"
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "……ふーん。じゃあこの胸が悪いってことか？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "alert",
      "text": "い、いえいえいえいえ！むしろありがたいです！！"
    },
    {
      "character": "タツ姐",
      "expression": "smile",
      "text": "……バカじゃねぇの。ま、凝ってるのは事実だけどな。",
      "characterImage": "tatsu/tatsu.png",
      "next": "change_clothes"
    },
    {
      "id": "change_clothes",
      "character": "player",
      "expression": "normal",
      "text": "それでは、施術用のウェアにお着替えをお願いします。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "はいはい…慣れたよ、この布切れにも。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "",
      "expression": "normal",
      "text": "（タツ姐が着替え始める…）",
      "cutInImage": "tatsu_changing"
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "…見んなっつってんだろ。",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_changing"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "着替えたぞ。…早く始めろ。",
      "characterImage": "tatsu/tatsu.png",
      "outfit": "micro_bikini"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（やっぱり毎回、目のやり場に困るな…）"
    },
    {
      "id": "massage_start",
      "character": "player",
      "expression": "normal",
      "text": "それでは、施術を始めさせていただきます。"
    }
  ]
}
