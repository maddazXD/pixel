{
  "dialogues": [
    {
      "character": "player",
      "hideCharacter": true,
      "text": "──4週目の朝。\nタツ姐との施術も1ヶ月が経過した。"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（借金返済はまだ遠いけど、タツ姐は毎週来てくれてる…）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（利子猶予のおかげで何とか持ちこたえてる…このまま客が増えれば…！）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "triggerWeeklySettlement": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（…やっぱり厳しい。早く新規客が来てくれないと…）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "おう。今日も来てやったぞ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "タツ姐さん！いつもありがとうございます。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "ま、お前の施術…正直、クセになるな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "surprised",
      "text": "え？本当ですか！",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "smile",
      "text": "ああ。先週も仕事終わりに肩が軽くてな。いつもなら頭痛がするのに、全然こなかった。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "それは良かったです！効果が出ているようで。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "だからさ、組のモンにも勧めてやるよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "あと、ウチの客にも紹介してやってもいいぞ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "本当ですか！？それは助かります！",
      "hideCharacter": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（やった！新規客が…！…って、組のモンと、タツ姐の客って…）"
    },
     {
      "character": "player",
      "hideCharacter": true,
      "text": "（男ばっかり来ることになるじゃないか！はぁ…。巨乳美少女が来てくれないかな…。）"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "まぁ、アタシが紹介する客だ。ちゃんとした施術しろよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "は、はい！もちろんです！",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "で、今日なんだけどよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "最近、接待飲みが続いててな…腹のあたりが重いんだよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "腹が重い、ですか。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "結構デスクワークも多いし、動かねぇからな。なんか張ってる感じがするんだよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "なるほど…それなら今日は仰向けで施術してみましょうか。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "仰向け？今までと違うのか？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "はい。仰向けだとお腹周りの筋肉や内臓にしっかりアプローチできます。",
      "hideCharacter": true
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "腹部の血流を改善すれば、消化器系の調子も整いますよ。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…ふーん。まぁ、効果あるならやってみるか。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "id": "choice_massage4",
      "character": "player",
      "expression": "normal",
      "text": "お腹の張りは放っておくと良くないですからね。",
      "hideCharacter": true,
      "choices": [
        {
          "label": "お酒の席が多いと大変ですね",
          "trustDelta": 2,
          "developDelta": 0,
          "next": "sympathy_path"
        },
        {
          "label": "内臓の調子を整える施術をしますね",
          "trustDelta": 1,
          "developDelta": 1,
          "next": "medical_path"
        },
        {
          "label": "直接お腹を確認させてください",
          "trustDelta": 0,
          "developDelta": 2,
          "next": "lift_path"
        }
      ]
    },
    {
      "id": "sympathy_path",
      "character": "player",
      "expression": "normal",
      "text": "社長だと接待とか飲み会とか、断れないことも多いんですよね。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…ま、そういうもんだ。組を回すには付き合いも大事だからな。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "身体に負担をかけてる分、しっかりケアしていきますね。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "smile",
      "text": "…そういうの、悪くねぇな。頼むわ。",
      "characterImage": "tatsu/tatsu.png",
      "next": "change_clothes"
    },
    {
      "id": "medical_path",
      "character": "player",
      "expression": "normal",
      "text": "内臓の調子を整える特別な手技があります。ちょっと刺激が強いかもしれませんが。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "刺激が強い？まぁ、効果あるならいいけどよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "腹部のツボを刺激して、消化器系の働きを活性化させるんです。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…ふーん。ちゃんとやってくれよ。",
      "characterImage": "tatsu/tatsu.png",
      "next": "change_clothes"
    },
    {
      "id": "lift_path",
      "character": "player",
      "expression": "normal",
      "text": "服をたくし上げて、直接お腹の状態を確認させていただけますか？",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "alert",
      "text": "…は？腹を見せろって？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "はい。視診も大事なんです。張りなどの状態を確認するには直接見るのが一番確実で。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…まぁ、診察ってんなら。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "",
      "expression": "normal",
      "text": "（タツ姐が自分で服をたくし上げる。）",
      "cutInImage": "tatsu_belly_show"
    },
    {
      "character": "タツ姐",
      "expression": "embarrassed",
      "text": "…見るだけだぞ？変なとこ、触るなよ。",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_belly_show"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（…呼吸に合わせて、柔らかそうなお腹がほんのり上下してる…）",
      "hideCharacter": true,
      "cutInImage": "tatsu_belly_show"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（少し汗ばんでて…きゅっとしたへそと、その下のラインが美しい…）",
      "hideCharacter": true,
      "cutInImage": "tatsu_belly_show"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（あと、もう少し服を上げたら……）",
      "hideCharacter": true,
      "cutInImage": "tatsu_belly_show"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "……あの、もう少しだけ、上まで上げてもらえますか？"
    },
    {
      "character": "タツ姐",
      "expression": "embarrassed",
      "text": "……こうか？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（おおっ…ブラが見えて…！やば…）",
      "hideCharacter": true,
      "cutInImage": "tatsu_belly_show"
    },
    {
      "character": "タツ姐",
      "expression": "embarrassed",
      "text": "…おい！今どこ見てた！？",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_belly_show"
    },
    {
      "character": "player",
      "expression": "alert",
      "text": "す、すみません！確認してただけで…！",
      "hideCharacter": true,
      "cutInImage": "tatsu_belly_show"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…で、どうなんだ？",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "確かに張ってますね。今日の施術でしっかりほぐしていきます。",
      "hideCharacter": true,
      "next": "change_clothes"
    },
    {
      "id": "change_clothes",
      "character": "player",
      "expression": "normal",
      "text": "それでは、施術用のウェアにお着替えをお願いします。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "ああ、わかった。…もう4回目だしな、慣れたよ。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "",
      "expression": "normal",
      "text": "（タツ姐が手慣れた様子で着替え始める…）",
      "cutInImage": "tatsu_changing"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "（…まぁ、効果あるしな。これくらいは我慢するか…）",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_changing"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "着替えたぞ。",
      "characterImage": "tatsu/tatsu.png",
      "outfit": "micro_bikini"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（何回見ても慣れないな、このプロポーション…）",
      "hideCharacter": true
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "今日は仰向けで施術しますので、ベッドに横になってください。",
      "hideCharacter": true
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…任せる。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "id": "massage_start",
      "character": "player",
      "expression": "normal",
      "text": "それでは、施術を始めさせていただきます。"
    }
  ]
}
