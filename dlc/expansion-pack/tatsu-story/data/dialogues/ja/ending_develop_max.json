{
  "dialogues": [
    {
      "character": "",
      "hideCharacter": true,
      "text": "──3ヶ月後。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…おう。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "いらっしゃい。…あー、今日も下着ダメだったんですね。スカートのとこ、ちょっとシミできてますよ。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…事務所出る前に替えたのに、車の中でオイルの匂いとお前の手を思い出したら、もうダメになった。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "はいはい、いつものですね。替えの下着は棚の上に置いてあるんで、着替えてきてください。"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "…もう専用の棚があるのかよ。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "毎週ぐしょぐしょのを持ってくるんで、まとめ買いしときました。サイズもう覚えちゃいましたよ。"
    },
    {
      "character": "player",
      "text": "（闇金の社長の替え下着を常備してる整体院。もう何がなんだか分からない。）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──施術中"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "じゃあ背中からいきますね。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "んっ…♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "触っただけでもう腰がビクってなりましたね。…ほんと、可愛い身体してますよ。触るたびに正直に反応してくれて。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…うるせぇ…♡ お前の手に身体が反応するようになっちまったんだから仕方ねぇだろ…♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "腰いきますよ。…あー、もう太もも伝ってますね。いつもながらすごい量。"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "…いちいち報告すんな…♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "じゃあ、いつものいきますか。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…っ♡ …ああ。早く入れて…♡ アタシのまんこ、もう一週間ずっとお前のちんぽ待ってたんだよ…♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "text": "（「いつもの」が何を指すか、もうお互い説明不要になってる。）"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "入れますよ。…うわ、一週間ぶりなのにぬるぬるで根元まで全部入った。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "んお゛おっ♡♡ お…奥まで来てる…♡♡ やっぱりちんぽが中にあると落ち着く…♡♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "落ち着くって言いながら中きゅうきゅう締めてきてますけど。…じゃあ動きますね。叩きながら奥まで突きます。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "パンッ！"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "ひっ♡♡ ケツ叩かれると…まんこがきゅうって締まっちゃう…お゛んッ♡♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "うわ、ほんとだ。叩くたびに中がぎゅって締まって、すごい吸い付いてくる。エロすぎですよタツ姐。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "パンッ パンッ パンッ！"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "あ゛っ♡♡ ケツに響いて…奥まで振動が…ぁっ…お゛っ♡♡ もっと…もっと叩きながら突いて……お゛ぉぉっ♡♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "もうお尻真っ赤ですよ。…けど、叩くほど中が締まるからこっちも気持ちいい。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "パァァンッ！！"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "ひぃっ♡♡♡ まんこ痙攣してっ…♡♡♡ あっ…イくっ…イくぅっ…んんっ…お゛ぉぉっ♡♡♡",
      "outfit": "bikini"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "びしゃっ…と施術台が濡れていく。"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "はい、1回目。…シーツ替えますんで、ちょっと抜きますね。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…っ♡ 抜くな…♡ まだ中にいろよ…♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "シーツびちゃびちゃですって。…ほら、大人しくしててください。"
    },
    {
      "character": "player",
      "text": "（闇金の社長がちんぽ入れたままケツ叩かれておもらしして、俺が黙々とシーツを替える。もう完全に日常になってしまった。）"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "替えました。…ほら、また入れてあげますよ。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "んお゛っ♡♡ …はぁ…やっぱりちんぽが入ってないとダメだ…♡♡ このクソまんこ、もうお前なしじゃ生きていけねぇ…みたいだ…♡♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "素直でいいですね。…闇金の社長のそういうところ、けっこう好きですよ。"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "…っ♡ いちいち恥ずかしいこと言うな…♡♡",
      "outfit": "bikini"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "パァンッ！ パァンッ！"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "ひゃっ♡♡♡ また締まっ…お゛おぉっ♡♡ ケツ叩かれるたびに子宮が降りてくる…あ゛ぁっダメ、もうイくっ…お゛ぉぉぉっ♡♡♡",
      "outfit": "bikini"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "びしゃぁっ…"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "2回目。…今日も盛大ですね。ほんと、イく時の顔がエロくて最高ですよ。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "はぁ…はぁ…♡ …バカ…そういうの言われると…もっと出ちゃうだろ…♡",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "いいですよ、いくらでも出してください。替えのシーツなら山ほどあるんで。"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "…アタシ専用のシーツまであんのかよ。",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "下着と同じです。業務上の必要経費。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──その後も、挿入→ケツ叩き→絶頂おもらし→シーツ交換のサイクルが延々と続いた。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──施術後"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "はぁ…はぁ…♡ …今日、何回イった？自分じゃもう数えらんねぇ…。",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "イったのが11回、おもらしが7回。シーツは8枚使いました。先週の記録更新ですよ、おめでとうございます。"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "…記録つけてんじゃねぇよ。おめでとうもクソもねぇ。",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "施術記録は基本ですから。…でもまぁ、毎週記録更新してくるタツ姐はすごいと思いますよ。身体の素質が違う。"
    },
    {
      "character": "タツ姐",
      "expression": "closeeyes",
      "text": "…褒めてんのかバカにしてんのか分かんねぇよ…。",
      "outfit": "bikini"
    },
    {
      "character": "タツ姐",
      "expression": "closeeyes",
      "text": "…なぁ。アタシ、もうダメなのかな。闇金の社長が毎週ケツ真っ赤にして、泣きながらおもらしして帰ってくんだぞ。…部下が知ったら終わりだ。",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "いいじゃないですか。普段は部下をシメてるくせに、ここに来るとケツ叩かれてイキ狂ってる。…そのギャップ、俺はすごく好きですよ。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…っ。…バカ。そういうこと言うから…来週も来ちまうんだろ…。",
      "outfit": "bikini"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…このクソまんこが、お前のちんぽとケツ叩きを求めて疼いて仕方ねぇんだよ…♡",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "来週も待ってますよ。シーツと下着、もっと多めに補充しときますね。"
    },
    {
      "character": "タツ姐",
      "expression": "closeeyes",
      "text": "…来週もな。",
      "outfit": "suit"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "闇金の社長が毎週ケツを叩かれに通ってくる整体院。\n替えの下着と替えのシーツが山積みされている。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "異常だけど、もうお互い慣れた。\nこれが、俺たちの日常だ。",
      "triggerEnding": "develop_max"
