{
  "dialogues": [
    {
      "character": "",
      "hideCharacter": true,
      "text": "──数ヶ月後。\n整体院は開けている日のほうが少なくなっていた。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "売上のほとんどはカジノに消え、タツ姐への返済も止まっている。"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "わぁ♡ お客様、今日も来てくれたんですね～！ えへへ、すごく嬉しいです♡"
    },
    {
      "character": "player",
      "text": "（……また来ちまった。今日こそ来ないって決めてたのに……）"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "ふふっ、お客様はもうこのお店の特別な常連さんです♡ 毎日来てくれてありがとうございます♡"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "他に客……いないよな？"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "はい♡ 完全貸し切りです。私のこと、独り占めしていいんですよ～？"
    },
    {
      "character": "player",
      "text": "（やばい。完全に嵌まってる……）"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "じゃあいつものハイ&ロー、始めましょうか♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "3連勝でおっぱい、6連勝でおまんこを晒すルール。\n毎日やってるせいで、もう勝負は秒で終わってしまう。"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "10連勝～！ お客様、今日もすごいです♡"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "えへへ……10連勝のご褒美、わかってますよね？"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "バニー店員はテーブルの上に腰を乗せ、股布をずらして脚を大きく開いた。カードの上でピンク色に光る秘部が丸見えになる。"
    },
    {
      "character": "player",
      "text": "（……何度見ても、エロすぎる……）"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "今日はちょっと特別ですよ♡ おちんちんを挿れたまま、次のゲームしませんか…？"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "え？　挿れたまま……？"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "はい♡ おちんちんを奥まで入れて……そのまま動かずに、次のハイ&ローやってみましょう？"
    },
        {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "勝った方が動いていいってルールです♡　途中で動いちゃだめですよ～？"
    },
    {
      "character": "player",
      "text": "いいね…！やろう！"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "ふふっ♡　お客様ならそう言ってくれると思ってました♡　じゃあ、さっそく……♡"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "んっ……♡ ああっ、太い……♡ 奥まで来てる……はぁ……♡"
    },
    {
      "character": "player",
      "text": "（くっ……中が熱くて、きゅうきゅう締め付けてくる……）"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "動いちゃダメですよ……？ えへへ、次はハイですかローですか～？"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "深く挿入したまま、カードをめくる。\n彼女の内壁が時々びくんと痙攣し、熱い蜜が溢れてくる。"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "あっ……♡ 動いてないのに……すごく…気持ちいいです……♡ お客様の熱いのが、子宮に当たってる……"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "……よし。次も勝った。"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "きゃんっ♡ あんまり勝たれたら……私、我慢できなくなっちゃいますよ……？"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "ねぇ……少しだけ、腰動かしてもいいですか……？ ほんの少しだけ……"
    },
    {
      "character": "player",
      "text": "（やばい……挿れたままゲームするの、想像以上に…いい……）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "俺は結局我慢できなくなり、テーブルを揺らして激しく彼女を突き上げる。\nカードとチップが散らばる中、彼女は甘い声を上げ続けた。"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "あっ♡ あっ♡ もう…だめ……♡ 膣内に、出してください……♡ お客様の…熱いので…私のおまんこ、いっぱい満たしてください…♡"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "うっ……！"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "びゅるるっ、びゅっ、びゅるるるっ……！\n大量の精液が子宮に注がれる。"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "あぁ……♡ 熱いぃ……♡ いっぱい出てる……♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──さらに数日後。"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "はぁ……はぁ……♡ 今日もいっぱい…おまんこに射精していただけて…気持ちよかったです♡"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "あ、そうだ♡ 明日、新しいゲームが入るんですよ～！"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "あ、明日は久しぶりに整体の予約が入ってたんだよね…。"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "え～？　来てくれないんですかぁ…？ 新しいゲーム、お客様のために考えたのに……特別ルール付きですよ？"
    },
    {
      "character": "バニー店員",
      "hideCharacter": true,
      "text": "どんなゲームかは、来てからのお楽しみ♡ きっと今よりずっとドキドキしますよ～？"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "……絶対行くよ。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "スマホにはタツ姐からの着信がまた増えていた。\nでも、そんなことより明日の新ゲームのほうが気になってしまう。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──それからの日々。\n朝、カジノへ直行。深く挿れたままゲームをし、店員さんのおまんこに射精して、ゲームで遊ぶ。\n整体院は半分廃墟。借金は増える一方。\nでもカジノのポイントはもうすぐゴールド会員目前だった。",
      "triggerEnding": "shop"
    }
  ]
