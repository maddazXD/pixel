    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…っ。まぁ、お前の手は…確かに、効くからな…。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "text": "（もう完全に依存してる…最高の状態だ。）"
