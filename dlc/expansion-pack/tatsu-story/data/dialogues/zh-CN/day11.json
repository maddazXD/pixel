    {
      "character": "player",
      "text": "（被手下发现了大量按摩成人片的高利贷老板…）"
    },
    {
      "character": "龙姐",
      "expression": "angry",
      "text": "'是教材！！学习用的！！别再问了！！'我虽然吼了回去…但他肯定不信…",
      "outfit": "suit"
