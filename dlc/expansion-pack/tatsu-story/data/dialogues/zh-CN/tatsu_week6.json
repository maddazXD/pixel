    {
      "character": "龙姐",
      "expression": "normal",
      "text": "嗯。都第六次了，已经习惯了。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "",
      "expression": "normal",
      "text": "龙姐开始换衣服",
      "cutInImage": "tatsu_changing"
    },
    {
      "character": "龙姐",
      "expression": "embarrassed",
      "text": "（……深入的治疗，到底打算做什么……）",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_changing"
    },
    {
      "character": "龙姐",
      "expression": "shy",
      "text": "（……算了，到目前为止他也没做过什么奇怪的事……）",
