    {
      "character": "타츠네",
      "expression": "shy",
      "text": "…윽. 뭐… 네 손이… 확실히 효과는 있으니까…",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "(완전히 빠져 있어… 완벽하다.)",
      "hideCharacter": true
