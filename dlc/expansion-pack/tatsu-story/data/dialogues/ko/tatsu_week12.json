    {
      "character": "타츠네",
      "expression": "shy",
      "text": "...네 손이...10개라면...어떨까 하고...",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "surprised",
      "text": "10개나...!?"
