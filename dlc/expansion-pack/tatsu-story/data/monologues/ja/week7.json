{
  "dialogues": [
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（タツ姐が帰った後……）",
      "playSE": "door_close"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（夢に俺が出てくるって……朝起きたら下着が濡れてるって……）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（あの人の身体、完全に変わり始めてる）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（乳首が敏感になって、日中でも急に身体が熱くなるって言ってた）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（施術の前からもう……準備ができてる状態だったな）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（闇金のボスがこんな状態になるなんて、誰が想像できた？）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（……俺の施術がここまで変えたんだ。整体師として、悪い気はしない）"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（さて、今週はどうしようか……）"
    }
  ]
}