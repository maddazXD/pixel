    },
    {
      "character": "Tatsu-nee",
      "text": "......Sudah datang. Itu dia datang. Nomor 8 berhasil masuk.",
      "characterImage": "tatsu/tatsu_date_smile.png"
    },
    {
      "character": "player",
      "text": "Kamu bercanda!?",
