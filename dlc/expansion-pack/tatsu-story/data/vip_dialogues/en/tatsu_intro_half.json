      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "...Hmph. Tentu saja.",
      "characterImage": "tatsu/tatsu_date_smile.png"
    },
    {
      "character": "",
      "text": "......",
      "hideCharacter": true
    },
    {
      "character": "Tatsu-nee",
      "text": "...Sebenarnya, lumayan juga.",
