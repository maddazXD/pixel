    },
    {
      "character": "player",
      "text": "Mau bir juga?",
      "characterImage": "tatsu/tatsu_date_normal.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Iya. ...Ngomong-ngomong, pilihanmu tadi payah banget. Memilih Nomor 3 itu benar-benar langkah amatiran.",
      "characterImage": "tatsu/tatsu_date_normal.png"
    },
    {
      "character": "player",
      "text": "Maaf...",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Lain kali aku bakal buatkan analisis yang benar buatmu. Prediksi kita bakal lebih akurat kalau kita kerja sama.",
