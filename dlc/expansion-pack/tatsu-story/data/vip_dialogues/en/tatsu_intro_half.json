    {
      "character": "Tatsu-nee",
      "text": "YEEESSSS!!",
      "characterImage": "tatsu/tatsu_date_smile.png"
    },
    {
      "character": "player",
      "text": "Tunggu, Nomor 6 menang...!?",
      "characterImage": "tatsu/tatsu_date_normal.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Sudah kubilang! Jangan remehkan mataku dalam menilai bakat!",
      "characterImage": "tatsu/tatsu_date_smile.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Nah sekarang, birnya.",
      "characterImage": "tatsu/tatsu_date_normal.png"
    },
    {
      "character": "player",
      "text": "...Iya, Bu. Aku ambilkan sekarang.",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "",
      "text": "......",
      "hideCharacter": true
    },
    {
      "character": "Tatsu-nee",
      "text": "Oke. Selanjutnya, Nomor 8. Taruhan menang.",
      "characterImage": "tatsu/tatsu_date_normal.png"
