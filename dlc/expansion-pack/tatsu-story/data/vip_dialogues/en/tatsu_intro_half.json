{
  "title": "50% Utang Terbayar - Kencan Balap Kuda",
  "dialogues": [
    {
      "character": "Tatsu-nee",
      "text": "Yo. Kamu sudah melunasi tepat setengahnya.",
      "characterImage": "tatsu/tatsu_normal_suit.png"
    },
    {
      "character": "player",
      "text": "Iya. Berkat kamu.",
      "characterImage": "tatsu/tatsu_closemouth_suit.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Hah. Kamu tidak bilang 'berkat kamu' ke rentenir.",
      "characterImage": "tatsu/tatsu_normal_suit.png"
    },
    {
      "character": "player",
      "text": "...Um, Tatsu-nee. Untuk merayakan pelunasan setengahnya, maukah kamu menghabiskan hari liburmu nanti bersamaku?",
      "characterImage": "tatsu/tatsu_closemouth_suit.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "......Hah?",
      "characterImage": "tatsu/tatsu_sweat_suit.png"
    },
    {
      "character": "player",
      "text": "Mungkin berlebihan kalau disebut kencan, tapi... sebagai ucapan terima kasih untuk semuanya.",
      "characterImage": "tatsu/tatsu_closemouth_suit.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "...K-kencan?",
      "characterImage": "tatsu/tatsu_shy_suit.png"
    },
    {
      "character": "player",
      "text": "Oh, tidak semewah itu kok. Cuma ke tempat yang seru saja.",
      "characterImage": "tatsu/tatsu_closemouth_suit.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "............",
      "characterImage": "tatsu/tatsu_closeeyes_suit.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "(Kencan... Apa dia baru saja bilang kencan...?)",
      "characterImage": "tatsu/tatsu_sweat_suit.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "(Kencan dengan debitur itu gila...! Tapi... katanya tempat yang seru...)",
      "characterImage": "tatsu/tatsu_shy_suit.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "(Akuarium...? Taman hiburan...? Atau mungkin restoran dengan pemandangan malam...?)",
      "characterImage": "tatsu/tatsu_shy_suit.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "...Cih. Baiklah. Aku ikut.",
      "characterImage": "tatsu/tatsu_closeeyes_suit.png"
    },
    {
      "character": "player",
      "text": "Makasih! Kalau begitu, hari Minggu ya.",
      "characterImage": "tatsu/tatsu_closemouth_suit.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "B-bukan berarti aku menantikannya atau apa ya!",
      "characterImage": "tatsu/tatsu_shy_suit.png"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Oke, dia bilang iya. Hari Minggu di pacuan kuda bersama Tatsu-nee... ini bakal seru.)"
    },
    {
      "character": "player",
      "text": "",
      "hideCharacter": true,
      "choices": [
