    {
      "id": "keiba_start",
      "character": "Tatsu-nee",
      "text": "...Hei.",
      "characterImage": "tatsu/tatsu_date_closeeyes.png",
      "background": "keiba_bg",
      "changeBGM": "zawameki"
    },
    {
      "character": "player",
      "text": "Ya?",
      "characterImage": "tatsu/tatsu_date_closeeyes.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "...Ini pacuan kuda, kan.",
      "characterImage": "tatsu/tatsu_date_closeeyes.png"
    },
    {
      "character": "player",
      "text": "Iya. Aku bilang tempat yang seru, kan?",
      "characterImage": "tatsu/tatsu_date_closeeyes.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "(Apa yang sebenarnya kuharapkan... Kenapa aku dandan sedikit untuk ini...)",
      "characterImage": "tatsu/tatsu_date_closeeyes.png"
    },
    {
      "character": "player",
      "text": "Aku kadang ke sini buat cari uang tambahan untuk cicilan, tapi rasanya sepi kalau sendirian.",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Melunasi utang ke rentenir pakai uang menang pacuan kuda... Kamu sudah gila.",
      "characterImage": "tatsu/tatsu_date_sweat.png"
    },
    {
      "character": "player",
      "text": "Hahaha...",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "...Yah, aku memang suka judi. Kita sudah di sini, jadi ya sudahlah.",
      "characterImage": "tatsu/tatsu_date_closeeyes.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Tapi kamu yang bayarin taruhanku ya. Ini kan 'kencan', kan?",
      "characterImage": "tatsu/tatsu_date_smile.png"
    },
    {
      "character": "player",
      "text": "I-Iya...",
      "characterImage": "tatsu/tatsu_date_smile.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Coba kulihat. Kartu balapannya.",
      "characterImage": "tatsu/tatsu_date_normal.png"
    },
    {
      "character": "player",
      "text": "Ini dia.",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "............",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "...Nomor 6. Nggak perlu lihat paddock segala. Silsilahnya bagus banget.",
      "characterImage": "tatsu/tatsu_date_normal.png"
    },
    {
      "character": "player",
      "text": "Masa sih? Aku tadinya mikir Nomor 3, si pengejar itu--",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Hah? Gaya lari Nomor 3 sama sekali nggak cocok. Lintasan hari ini lagi berat.",
      "characterImage": "tatsu/tatsu_date_normal.png"
    },
    {
      "character": "player",
      "text": "...Kamu beneran paham ginian?",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Kalau sudah kelamaan jalanin bisnis pinjaman, kamu bakal jago analisis data. Menilai kemampuan bayar debitur sama kemampuan kuda -- itu sama saja.",
      "characterImage": "tatsu/tatsu_date_normal.png"
    },
    {
      "character": "player",
      "text": "Analogi macam apa itu...",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Heh. Kita taruhan saja. Nomor 3 pilihanmu lawan Nomor 6 pilihanku. Yang kalah beliin bir.",
      "characterImage": "tatsu/tatsu_date_smile.png"
    },
    {
      "character": "player",
      "text": "Boleh juga.",
      "characterImage": "tatsu/tatsu_date_smile.png"
    },
    {
      "character": "",
      "text": "Balapan dimulai.",
      "hideCharacter": true,
      "changeBGM": "hoserase"
    },
    {
      "character": "Tatsu-nee",
      "text": "...Tikungan terakhir... Ya, Nomor 6 mulai maju...!",
      "characterImage": "tatsu/tatsu_date_smile.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Ayo! Salip mereka! Salip merekaaa!!",
      "characterImage": "tatsu/tatsu_date_angry.png"
    },
    {
      "character": "player",
      "text": "(Tatsu-nee serius banget... Dia kelihatan lebih serem daripada pas lagi nagih utang...)",
      "characterImage": "tatsu/tatsu_date_angry.png"
