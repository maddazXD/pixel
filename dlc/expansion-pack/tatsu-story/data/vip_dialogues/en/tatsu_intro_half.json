    {
      "character": "player",
      "text": "Nomor 8? Itu kan unggulan ke-10!",
      "characterImage": "tatsu/tatsu_date_closemouth.png"
    },
    {
      "character": "Tatsu-nee",
      "text": "Justru karena itu. Odds-nya menggiurkan.",
