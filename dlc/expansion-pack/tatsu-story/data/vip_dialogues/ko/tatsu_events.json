{
  "full_repaid": {
    "title": "빚 완납 달성 기념 - 온천 여행",
    "dialogues": [
      {
        "character": "타츠네",
        "text": "……내가 씻겨줄게. 너를.",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "아니, 그건——",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "복수야. 가만히 앉아 있어.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "몸으로 씻겨주는 거야.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "……같은 거요?",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "(복수야……복수라고……!)",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "가만히 있어. 위에 올라갈 테니까.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "에엣……!?",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……비누, 발랐어.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "타츠네 씨……어디를 씻으실 생각이에요?",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……온몸이지 당연히!",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "방금 그 사이는 뭐예요……",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "시끄러워! 간다!",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……읏",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……뭐, 뭐야 이거……따뜻해……",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "타츠네 씨 쪽이……더 따뜻한데요……",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……읏! 이상한 소리 하지 마!",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……음…♡ 움직인다.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……읏……미끌미끌해서……자꾸 미끄러져…♡",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "……읏……",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "어때……나한테 만져지는 기분은.",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "……큰일이에요……직접 닿아서……",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "당연하지. 씻기는 중이니까.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "(씻기는 거야……그냥 씻기는 것뿐이야……!)",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "음……♡ 문질러지면서……이상한 느낌…♡",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "타츠네 씨, 소리 나오고 있어요.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "시, 시끄러…! 복수라고 했잖아…♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "너를 곤란하게 하는 게 목적이었는데……♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "왜 내가 더……기분 좋아지는 거야……♡",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "젠장, 비누 때문에……너무 미끄러워…♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "끝이……닿을 때마다……♡",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "타츠네 씨……이러다 들어갈 것 같은데……",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "안 넣었거든! 씻기는 중이라고!♡",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "앗…♡ 거기……직접 닿아서……♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "미쳤어……이런 거 처음이야……♡",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "……이제 못 참겠어요……",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "하? 벌써야? 한심하네.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "나는 아직——",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……읏♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "거짓말……나도……뭔가……♡",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "잠, 잠깐……너만 먼저 가지 마…!♡",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "……으으……!",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "앗……나오고 있어……따뜻해……!♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "배에……전부……♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "아……읏♡♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "나까지……읏♡♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……으으읏♡♡♡",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "하아…하아……",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "………….",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……안 넣었으니까.",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "……네.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "그냥 씻긴 것뿐이니까.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "……네.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……그런데 둘 다 간 건……뭐야 대체……",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "………….",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……대답하지 마. 안 물었어.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……다음 주. 예약 넣어놓을게.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "……시술이요?",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "그 외에 뭐가 있어.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……이제 특별 대우는 없어. 돈 내고 받을 거니까.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "네. 최고의 시술을 해드리겠습니다.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……손님, 이라.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……그게 전부야?",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "네?",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "아무 말도 안 했어!",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……오늘 일, 누구한테 말하면 죽여버린다.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "말 안 해요.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……쳇. 복수한다더니……최악이야.",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "……하지만요.",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "……뭐.",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "타츠네 씨가 씻겨줘서, 기뻤어요.",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "…………읏!",
        "tatsuImage": "default"
      },
      {
        "character": "타츠네",
        "text": "바보! 다시는 그런 말 하지 마!",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "(사금융 사장에, 입이 거칠고.)",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "(그런데 순정만화를 좋아하고, 부끄러우면 귀가 빨개지는 사람.)",
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "(나한테 타츠네 씨는……이미 그런 틀에 담을 수 있는 사이가 아니다.)",
        "resetBubbles": true,
        "tatsuImage": "default"
      },
      {
        "character": "player",
        "text": "(——본인한테 말하면 죽임을 당하겠지만.)",
        "tatsuImage": "default"
      }
    ]
  }
