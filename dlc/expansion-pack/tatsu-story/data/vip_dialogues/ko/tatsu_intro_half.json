{
  "title": "빚 50% 상환 달성 - 경마장 데이트",
  "dialogues": [
    {
      "character": "타츠네",
      "text": "어이. 상환이 딱 절반이네.",
      "characterImage": "tatsu/tatsu_normal_suit.png"
