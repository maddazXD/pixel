        { "character": "tatsu", "expression": "sleeping_01", "text": "车载音响也在放LiliCure的CD……听了一个小时就记住了" },
        { "character": "player", "expression": "normal_01", "text": "Yasu听起来是个好爸爸" },
        { "character": "tatsu", "expression": "normal_01", "text": "……嗯。那是他唯一的优点" }
