    "talk_name": {
      "topicName": "关于名字",
      "trustEffect": 4,
      "developEffect": 0,
      "alertnessEffect": -5,
      "pleasureEffect": 0,
      "sleepinessEffect": 0,
      "dialogues": [
        { "character": "player", "expression": "normal_01", "text": "说起来，问诊表上写的全名……龙海丽，对吧？" },
        { "character": "tatsu", "expression": "normal_01", "text": "……啊。那个" },
        { "character": "player", "expression": "normal_01", "text": "丽，很美的名字" },
        { "character": "tatsu", "expression": "normal_01", "text": "……别说了。别叫我那个名字" },
        { "character": "player", "expression": "normal_01", "text": "不喜欢吗？" },
        { "character": "tatsu", "expression": "alert_01", "text": "不配啊。高利贷老大叫『丽』。开什么玩笑" },
        { "character": "player", "expression": "normal_01", "text": "谁取的？" },
        { "character": "tatsu", "expression": "sleeping_01", "text": "……父亲取的。我出生的时候，希望我『长成一个美丽的人』" },
        { "character": "tatsu", "expression": "sleeping_01", "text": "……连他的脸都记不住了。就只留下了这个名字" },
        { "character": "player", "expression": "normal_01", "text": "……从名字的含义来看，他一定很珍惜你" },
        { "character": "tatsu", "expression": "normal_02", "text": "……谁知道呢。但我生活的世界对这个名字来说太残酷了" },
        { "character": "tatsu", "expression": "normal_02", "text": "所以就用『龙姐』了。……这样更实际" },
        { "character": "tatsu", "expression": "sleeping_01", "text": "……别告诉任何人。我刚才说的" }
      ]
    },

    "talk_scent": {
      "topicName": "精油的香味",
      "trustEffect": 3,
      "developEffect": 1,
      "alertnessEffect": -5,
      "pleasureEffect": 0,
      "sleepinessEffect": 2,
      "dialogues": [
        { "character": "player", "expression": "normal_01", "text": "最近治疗前闻到精油的味道，您的表情会放松下来呢" },
        { "character": "tatsu", "expression": "alert_02", "text": "……别那样盯着我看" },
