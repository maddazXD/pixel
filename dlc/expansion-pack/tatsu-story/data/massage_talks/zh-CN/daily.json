    "talk_stiff": {
      "topicName": "关于肩膀酸痛",
      "trustEffect": 1,
      "developEffect": 0,
      "alertnessEffect": -1,
      "pleasureEffect": 0,
      "sleepinessEffect": 2,
      "dialogues": [
        { "character": "player", "expression": "normal_01", "text": "肩膀酸是从什么时候开始的？" },
        { "character": "tatsu", "expression": "normal_02", "text": "……谁知道呢。有记忆以来就一直这样了。已经不知道不酸是什么感觉了" },
        { "character": "player", "expression": "normal_01", "text": "做办公室工作的人很常见的症状。长时间用电脑什么的" },
        { "character": "tatsu", "expression": "normal_02", "text": "做做账本、安排催收日程之类的。……与其说是肩膀，不如说后脖子一直很沉" },
        { "character": "player", "expression": "normal_01", "text": "(伏案工作确实是原因之一，但那对胸部的重量应该也是很大的负担……)" },
        { "character": "player", "expression": "normal_01", "text": "您的斜方肌非常僵硬。不定期放松的话，还会引起头痛" },
        { "character": "tatsu", "expression": "normal_01", "text": "……头痛确实经常有。还以为是偏头痛，原来是肩膀的问题？" },
        { "character": "player", "expression": "normal_01", "text": "可能性很大。持续接受治疗的话应该能改善" },
        { "character": "tatsu", "expression": "normal_02", "text": "……嗯。那走着瞧吧" }
      ]
    },

    "talk_first_time": {
      "topicName": "第一次来诊所",
      "trustEffect": 2,
      "developEffect": 0,
      "alertnessEffect": -5,
      "pleasureEffect": 0,
      "sleepinessEffect": 0,
      "dialogues": [
        { "character": "player", "expression": "normal_01", "text": "以前去过整骨院或者做过按摩吗？" },
        { "character": "tatsu", "expression": "normal_02", "text": "美容院一个月去两次，但是……这种直接用手做的还是第一次" },
        { "character": "player", "expression": "normal_01", "text": "紧张吗？" },
        { "character": "tatsu", "expression": "normal_01", "text": "……不紧张。完全不" },
        { "character": "player", "expression": "normal_01", "text": "但是肩膀硬得像石头一样" },
        { "character": "tatsu", "expression": "alert_02", "text": "……闭嘴。本来就这样" },
        { "character": "player", "expression": "normal_01", "text": "不会弄疼您的，放松交给我就好" },
        { "character": "tatsu", "expression": "sleeping_01", "text": "……嗯。……啊，跟美容院确实不一样" },
        { "character": "player", "expression": "normal_01", "text": "怎么不一样？" },
        { "character": "tatsu", "expression": "sleeping_01", "text": "……怎么说呢，感觉能触及更深的地方？美容院比较表面……" },
        { "character": "tatsu", "expression": "normal_01", "text": "……嘛，还不错。就这样" }
      ]
    },

    "talk_sleep": {
      "topicName": "睡眠习惯",
      "trustEffect": 1,
      "developEffect": 1,
      "alertnessEffect": -1,
      "pleasureEffect": 0,
      "sleepinessEffect": 3,
      "dialogues": [
        { "character": "player", "expression": "normal_01", "text": "平时怎么睡觉的？侧睡？仰卧？" },
        { "character": "tatsu", "expression": "normal_02", "text": "侧睡。仰卧的话……胸部太重压得喘不过气" },
        { "character": "player", "expression": "normal_01", "text": "是的，不过侧睡对肩膀负担更大" },
        { "character": "tatsu", "expression": "normal_02", "text": "什么姿势都对哪里有负担，也没办法" },
        { "character": "player", "expression": "normal_01", "text": "试试用抱枕吧。可以分散胸部的重量" },
        { "character": "tatsu", "expression": "alert_02", "text": "抱枕……你别想象我抱着抱枕睡觉的样子" },
        { "character": "player", "expression": "normal_01", "text": "没有" },
        { "character": "tatsu", "expression": "normal_02", "text": "……其实入睡本身就很困难。想的事情太多了" },
        { "character": "player", "expression": "normal_01", "text": "工作上的事？" },
        { "character": "tatsu", "expression": "sleeping_01", "text": "……嗯。明天的催收怎么办，那家伙干活靠不靠谱。脑子停不下来" },
        { "character": "player", "expression": "normal_01", "text": "治疗后可能会有点困，今晚早点休息吧" },
        { "character": "tatsu", "expression": "sleeping_01", "text": "……嗯。试试看吧" }
      ]
    },

    "talk_massage_effect": {
      "topicName": "按摩的效果",
      "trustEffect": 2,
      "developEffect": 1,
      "alertnessEffect": -3,
      "pleasureEffect": 0,
      "sleepinessEffect": 2,
      "dialogues": [
        { "character": "player", "expression": "normal_01", "text": "最近身体感觉怎么样？跟刚开始来的时候比" },
        { "character": "tatsu", "expression": "normal_01", "text": "……没什么特别的。就那样" },
        { "character": "player", "expression": "normal_01", "text": "跟第一次来的时候比，肩膀的僵硬程度柔软多了" },
        { "character": "tatsu", "expression": "normal_01", "text": "……是吗" },
        { "character": "player", "expression": "normal_01", "text": "皮肤状态也好了。这是血液循环改善的证据" },
        { "character": "tatsu", "expression": "alert_02", "text": "连人家的皮肤状态都观察得那么仔细啊……" },
        { "character": "player", "expression": "normal_01", "text": "职业习惯" },
        { "character": "tatsu", "expression": "normal_02", "text": "……嘛，最近确实容易入睡了一些。就一点点" },
        { "character": "player", "expression": "normal_01", "text": "那太好了。身体放松了的话，对自律神经也有好的影响" },
        { "character": "tatsu", "expression": "sleeping_01", "text": "……还有，治疗结束后身体会暖和好一阵子。回去的车上都是" },
        { "character": "tatsu", "expression": "normal_01", "text": "……我不是在夸你。只是说可能有点效果而已" },
        { "character": "player", "expression": "normal_01", "text": "是，我明白" },
        { "character": "tatsu", "expression": "normal_02", "text": "……你在笑吧？" }
      ]
    },

    "talk_work": {
      "topicName": "工作聊天",
      "trustEffect": 2,
      "developEffect": 0,
      "alertnessEffect": -3,
      "pleasureEffect": 0,
      "sleepinessEffect": 0,
      "dialogues": [
        { "character": "player", "expression": "normal_01", "text": "平时的工作都做些什么？" },
        { "character": "tatsu", "expression": "normal_02", "text": "放高利贷。借钱出去，收钱回来。就这样" },
        { "character": "player", "expression": "normal_01", "text": "催收也亲自去吗？" },
        { "character": "tatsu", "expression": "normal_02", "text": "大单子亲自去。不能被人小看" },
        { "character": "player", "expression": "normal_01", "text": "在这个行业里，作为女性站在顶端应该很不容易吧" },
        { "character": "tatsu", "expression": "normal_02", "text": "刚开始谁都不听我的。说什么『一个女的能干什么』" },
        { "character": "player", "expression": "normal_01", "text": "怎么让他们服气的？" },
        { "character": "tatsu", "expression": "normal_02", "text": "……靠拳头。练过武术，先把最壮的那个打趴下了" },
        { "character": "tatsu", "expression": "sleeping_01", "text": "然后把财务管理抓紧了。用数字拿出成绩，谁也没话说" },
        { "character": "player", "expression": "normal_01", "text": "真厉害……" },
        { "character": "tatsu", "expression": "normal_01", "text": "……辛苦是辛苦，但不讨厌这份工作。就是肩膀会酸" }
      ]
