    {
      "character": "player",
      "expression": "shy",
      "text": "（でも目が勝手に…やば…）"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "着替えたぞ。変なとこ見んじゃねぇぞ。",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（やっぱりすごいプロポーションだな...）"
