      "text": "（もみっ）",
      "cutInImage": "tatsu_shirimomi"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "っ…！！テメェ何しやがる！！",
      "outfit": "suit",
      "cutInImage": "tatsu_shirimomi"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "（す、すごい弾力…！）",
      "cutInImage": "tatsu_shirimomi"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "おい聞いてんのか！？どこ触ってんだ！！",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "だ、大臀筋の状態確認です！施術に必要な…！"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "……次やったらマジで指折るからな。",
      "outfit": "suit",
      "next": "change_clothes"
    },
    {
      "id": "change_clothes",
      "character": "player",
      "expression": "closemouth",
      "text": "その前に、施術用のウェアにお着替えをお願いします。"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "……またあの布切れかよ。",
      "outfit": "suit"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…ったく、マジで風邪ひくぞこれ。",
      "outfit": "suit"
    },
    {
      "character": "",
      "expression": "normal",
      "text": "（タツ姐がしぶしぶ着替え始める…）",
      "cutInImage": "tatsu_changing"
