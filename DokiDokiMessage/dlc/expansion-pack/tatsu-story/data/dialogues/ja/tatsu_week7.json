    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "triggerWeeklySettlement": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（客足も順調...タツ姐の紹介のおかげだ。このまま行けば、なんとか返済も...）"
