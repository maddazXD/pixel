    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "…っ！ さらっとそういう単語使うな…！",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "施術者ですからね、正確に話さないと。…で、自分の指だとちょうどいい圧力やリズムが再現できない。だからいくらイッても物足りなくなるんです。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "……お前の指以外じゃ……ダメなのか……？ くそ……。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "text": "（闇金の社長が、俺の指以外じゃダメだって…。最高すぎるだろ…。）"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…………認めたくねぇけど…お前の施術は…効くからな…。",
      "outfit": "suit"
