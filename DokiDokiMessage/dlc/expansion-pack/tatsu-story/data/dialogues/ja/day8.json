    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…おう。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "タツ姐さん！ 今日も…って、どうしました？ なんか顔色が…"
