    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…別に。ちょっと調子が悪いだけだ。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "調子が悪い、ですか。どんな感じです？"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…その、週末…ずっと身体が熱くて…眠れなかった。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "text": "（週末ずっと…！ 土曜も日曜もか…。）"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…なんか、身体の奥がムズムズして…落ち着かねぇんだよ。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "週末、何か自分で対処しようとしました？"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "…っ！ な、何でそんなこと聞くんだよ…。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "施術の参考にしたいので。何か試したなら教えてください。"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…仕事に没頭しようとしたんだけどよ。深夜まで資料整理して…。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "それで？"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…全然ダメだった。仕事してても、急に身体が疼いて集中できなくて…。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "他には？"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…冷水シャワー浴びた。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "text": "（冷水シャワーまで…相当追い詰められてたんだな…。）"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…余計ダメだった。水が肌に当たった瞬間、ビクッてなって…逆に変な感じになった…。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "…もしかして、それ以外にも何か試しました？"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "…っ！ いちいち聞くな…！",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "…自分で、触ってみたりとか。"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "……っ！！",
      "outfit": "suit"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "………………。",
      "outfit": "suit"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "……色々やってみたんだけど……その、一番敏感なとこを……何度も擦ったり、摘まんだりして……。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "一番敏感なところ、というと…前の方の、突起した部分ですね？"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "…っ！ はっきり言うなよ…！ ……まぁ…そこだよ……。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "それで、どうなりました？"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "……何回もイッたはずなのに……全然、満足できなくてよ……。すぐにまた疼いてきて……。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "text": "（何回もイッたのに満足できない…！ それだけクリトリスが開発されてるのか…。）"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "…何回くらい試しました？"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "…っ。……わかんねぇよ……。土曜の夜も、日曜の朝も…日曜の夜も……何回やっても、腫れるくらい弄ったのに、すぐにまた熱くなって……。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "text": "（週末ずっと…腫れるくらい自分で弄っても足りなかったのか…相当追い詰められてたんだな…。）"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "…最後はどうなりました？"
    },
    {
      "character": "タツ姐",
      "expression": "shy",
      "text": "……結局、全然収まんなくて……ヒリヒリ痛くなっても止められなくて……もう、泣きそうになりながら諦めた……。アタシが……こんな惨めなことしてんのかって……。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "text": "（腫れてヒリヒリするまで自分で弄り続けたのに…それでも足りなかった。あのプライドの塊みたいな人が、泣きそうになるくらい追い詰められてたのか…。）"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "なるほど…それはタツ姐さんの身体が、俺の指の動きを完全に記憶してしまったからですね。"
