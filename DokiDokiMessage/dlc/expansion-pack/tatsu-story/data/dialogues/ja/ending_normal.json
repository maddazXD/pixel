{
  "dialogues": [
    {
      "character": "",
      "hideCharacter": true,
      "text": "──半年後。\n整体院は相変わらず細々と営業していた。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "おう。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "いらっしゃい。今日も定刻ですね。"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "時は金なり、だからな。一分一秒も無駄にしたくねぇんだよ。…ほら、さっさと始めてくれ。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "text": "（半年間、毎週欠かさず通ってきてる。台風の日も来た。）"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "今日もいつものコースで？"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "ああ。肩と腰、重点的に頼む。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "了解です。じゃあ着替えてください。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──施術中"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "肩甲骨の内側、また固くなってますね。"
    },
    {
      "character": "タツ姐",
      "expression": "closemouth",
      "text": "…年末は融資の申し込みが多いんだよ。書類仕事が増える。",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "闇金も年末は忙しいんですね。"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "闇金って言うな。貸金業だ。",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "はいはい。…ここ押しますね。"
    },
    {
      "character": "タツ姐",
      "expression": "closemouth",
      "text": "…っ。",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "text": "（…今、ちょっとだけ肩がビクッてなった。）"
    },
    {
      "character": "player",
      "text": "（あの12週間の条件反射、まだ少し残ってるんだろうな…。）"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…なんだよ。手が止まったぞ。",
      "outfit": "bikini"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "いえ、何でもないです。続けますね。"
    },
    {
      "character": "player",
      "text": "（…もっと踏み込んでいたら、違う関係になってたのかもしれない。）"
    },
    {
      "character": "player",
      "text": "（…まぁ、これはこれでいいか。）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──施術後"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "ふぅ。…ああ、楽になった。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "お疲れさまでした。来週も同じ時間で？"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "当たり前だろ。",
      "outfit": "suit"
    },
    {
      "character": "タツ姐",
      "expression": "closemouth",
      "text": "…………。",
      "outfit": "suit"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "…なぁ。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "はい？"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "次の日曜、競馬あるけど。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "行きます？"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "この前の最終レースの負けを取り返す。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "3ヶ月くらい前から同じこと言ってません？"
    },
    {
      "character": "タツ姐",
      "expression": "angry",
      "text": "うるせぇ。今度こそだ。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "了解です。じゃあ日曜に。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──さらに数ヶ月後"
    },
    {
      "character": "player",
      "text": "（最近、タツ姐が来る時間帯に他の予約を入れられなくなった。）"
    },
    {
      "character": "player",
      "text": "（理由は単純。部下が黒塗りの車で迎えに来るから、他の客が怯えて帰る。）"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "おう。…なんか今日空いてんな。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "ええ、まぁ…。"
    },
    {
      "character": "player",
      "text": "（言えない。あなたのせいですとは絶対に言えない。）"
    },
    {
      "character": "タツ姐",
      "expression": "closeeyes",
      "text": "貸切みたいでいいじゃねぇか。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "text": "（…良くないんだけどな、経営的には。）"
    },
    {
      "character": "player",
      "text": "（でも、まぁ…タツ姐が毎週来てくれるおかげで、潰れずに済んでるのも事実だ。）"
    },
    {
      "character": "タツ姐",
      "expression": "normal",
      "text": "じゃあな。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "お疲れさまでした。"
    },
    {
      "character": "タツ姐",
      "expression": "closemouth",
      "text": "…………。",
      "outfit": "suit"
    },
    {
      "character": "タツ姐",
      "expression": "closeeyes",
      "text": "…来週もな。",
      "outfit": "suit"
    },
    {
      "character": "player",
      "expression": "closemouth",
      "text": "はい。来週も。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "毎週の施術と、たまの競馬。\n闇金の社長と整体師の、不思議な関係が続いている。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "それ以上でもそれ以下でもないけど、\n悪くない、と思う。",
      "triggerEnding": "normal"
    }
  ]
}
