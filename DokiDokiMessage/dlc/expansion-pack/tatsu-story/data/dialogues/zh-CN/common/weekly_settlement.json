      "conditions": {
        "minDebtPaidRatio": 0.3,
        "maxDebtPaidRatio": 0.6
      }
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（马上就能还清了……！和龙姐的关系也许会改变吧。）",
