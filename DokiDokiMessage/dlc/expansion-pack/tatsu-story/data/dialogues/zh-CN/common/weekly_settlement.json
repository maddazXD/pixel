    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（客人完全不来……龙姐的眼神好可怕……）",
      "conditions": {
        "maxCustomerCount": 1
      }
    },
    {
      "character": "player",
      "hideCharacter": true,
