    {
      "character": "龙姐",
      "expression": "embarrassed",
      "text": "嗯。明明什么都没做，就突然心跳加速……没法集中精力。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "龙姐",
      "expression": "shy",
      "text": "……光是内衣擦过去就会一激灵……乳头变得特别敏感……",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（那是……完全开始性觉醒了……）",
      "hideCharacter": true
