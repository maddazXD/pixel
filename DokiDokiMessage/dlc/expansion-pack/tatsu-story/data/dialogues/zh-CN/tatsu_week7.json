    {
      "character": "龙姐",
      "expression": "normal",
      "text": "工作的时候也老是走神，真是头疼。",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "（完美。照这个势头，今天可以大胆进攻了……）",
      "hideCharacter": true
