    {
      "character": "player",
      "expression": "smile",
      "text": "明白了。今天也会好好照顾你的。"
    },
    {
      "character": "龙姐",
      "expression": "normal",
      "text": "...嗯。拜托了。",
      "characterImage": "tatsu/tatsu.png"
