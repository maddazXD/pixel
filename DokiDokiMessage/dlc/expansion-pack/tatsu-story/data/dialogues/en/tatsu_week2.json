{
  "dialogues": [
    {
      "character": "player",
      "hideCharacter": true,
      "text": "──Pagi di minggu kedua sejak pembukaan. Melihat tumpukan tagihan yang diselipkan diam-diam ke kotak suratku, kepalaku jadi pening."
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Listrik, air, sewa... Gawat, aku bangkrut...)"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "triggerWeeklySettlement": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Uangku makin menipis... Tatsu-nee masih jadi satu-satunya pelangganku.)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Tapi setidaknya aku dapat penangguhan bunga... Aku harus berterima kasih pada Tatsu-nee.)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(...Tapi lagi pula, berterima kasih pada rentenir... kenapa bisa jadi begini...)"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "Tatsu-nee",
      "expression": "normal",
      "text": "Yo.",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "Tatsu-nee! Kamu datang!",
      "hideCharacter": true
    },
    {
      "character": "Tatsu-nee",
      "expression": "normal",
      "text": "...Yah, itu berhasil, aku akui itu.",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "Tatsu-nee",
      "expression": "normal",
      "text": "Setelah perawatan minggu lalu, bahuku terasa lebih ringan.",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "Benarkah!? Senang mendengarnya!",
      "hideCharacter": true
    },
    {
      "character": "Tatsu-nee",
      "expression": "normal",
      "text": "Jangan besar kepala. Hutang tetaplah hutang.",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "I-Iya, aku tahu...",
      "hideCharacter": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Tapi rasanya senang dia mengakui hasilnya...)"
    },
    {
      "character": "Tatsu-nee",
      "expression": "normal",
      "text": "Berkat itu, aku berhasil main mahjong tiga ronde.",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "smile",
      "text": "Itu luar biasa!",
      "hideCharacter": true
    },
    {
      "character": "Tatsu-nee",
      "expression": "normal",
      "text": "Jadi, apa rencananya hari ini?",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "Hari ini aku ingin fokus ke punggung dan pinggangmu.",
      "hideCharacter": true
    },
    {
      "character": "Tatsu-nee",
      "expression": "normal",
      "text": "Punggung dan pinggang, ya. Iya sih, bagian itu juga cukup kaku.",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "Aku ingin kamu berbaring telungkup untuk perawatannya.",
      "hideCharacter": true
    },
    {
      "character": "Tatsu-nee",
      "expression": "normal",
      "text": "Telungkup? Yah, kalau memang begitu caranya.",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "Iya. Aku akan memijat menyeluruh dari punggung sampai ke pinggangmu.",
      "hideCharacter": true
    },
    {
      "id": "choice_massage2",
      "character": "player",
      "expression": "normal",
      "text": "Bolehkah aku memeriksa kondisi punggung dan pinggangmu?",
      "hideCharacter": true,
      "choices": [
        {
          "label": "Periksa ketegangan otot punggungnya",
          "trustDelta": 2,
          "developDelta": 0,
