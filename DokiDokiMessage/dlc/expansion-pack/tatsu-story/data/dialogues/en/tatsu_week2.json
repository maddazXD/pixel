    {
      "id": "normal_path",
      "character": "player",
      "expression": "normal",
      "text": "Otot punggungmu tegang sekali. Biar aku kendurkan perlahan jaringan dalamnya.",
      "hideCharacter": true
    },
    {
      "character": "Tatsu-nee",
      "expression": "normal",
      "text": "...Yah, selama kamu tetap profesional, aku izinkan.",
      "characterImage": "tatsu/tatsu.png",
      "next": "change_clothes"
    },
    {
      "id": "hip_path",
      "character": "player",
      "expression": "normal",
      "text": "Kalau begitu... izinkan aku memeriksa sepanjang garis dari pinggang ke pinggulmu.",
      "hideCharacter": true
    },
    {
      "character": "",
      "expression": "normal",
      "text": "(Saat aku perlahan menelusuri area itu, otot-otot yang kencang merespons dengan kehangatan...)",
      "cutInImage": "tatsu_butt_check"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "(Wah... kencang sekali... H90 memang bukan main-main...)",
      "hideCharacter": true,
      "cutInImage": "tatsu_butt_check"
    },
    {
      "character": "Tatsu-nee",
      "expression": "embarrassed",
      "text": "Nn... Hei, jangan sentuh aku dengan cara yang aneh.",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_butt_check"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "M-Maaf! Aku cuma memeriksa ketegangan di otot bokongmu...",
      "hideCharacter": true,
      "next": "change_clothes"
    },
    {
      "id": "inner_path",
      "character": "player",
      "expression": "normal",
      "text": "...Permisi. Aku akan memeriksa aliran di sepanjang paha bagian dalammu.",
      "hideCharacter": true
    },
    {
      "character": "",
      "expression": "normal",
      "text": "(Menyentuh ringan pangkal pahanya...)",
      "cutInImage": "tatsu_inner_thigh"
    },
    {
      "character": "Tatsu-nee",
      "expression": "alert",
      "text": "...! H-Hei... jangan di situ...",
      "characterImage": "tatsu/tatsu.png",
      "cutInImage": "tatsu_inner_thigh"
    },
    {
      "character": "player",
      "expression": "normal",
      "text": "Aku cuma memeriksa aliran limfatiknya...",
      "hideCharacter": true,
      "cutInImage": "tatsu_inner_thigh"
    },
    {
      "character": "player",
      "expression": "shy",
      "text": "(...Apa cuma perasaanku saja, atau dia sedikit hangat...?)",
      "hideCharacter": true,
      "cutInImage": "tatsu_inner_thigh"
    },
    {
      "character": "Tatsu-nee",
      "expression": "embarrassed",
      "text": "...Jangan salah paham. Itu bukan reaksi apa-apa.",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "expression": "alert",
      "text": "T-Tentu saja tidak!",
      "hideCharacter": true,
