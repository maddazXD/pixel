{
  "dialogues": [
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Minggu ke-12... 3 bulan ini benar-benar berlalu begitu cepat)",
      "playSE": "door_close"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Berkat Nana-chan, reputasi klinik ini sedang berada di puncaknya)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Dia datang hampir setiap hari, aku benar-benar bersyukur)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Kemampuan pengobatanku meningkat drastis, dan aku telah mengembangkan teknik-teknik baru)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Sekarang tinggal utangnya saja. Batas waktu pelunasannya minggu ini.)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Kalau aku tidak bisa membayarnya...)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Aku harus memastikan tidak ada penyesalan.)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Baiklah, apa yang harus kulakukan sekarang...)"
    }
  ]
}