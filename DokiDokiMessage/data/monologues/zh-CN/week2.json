{
  "dialogues": [
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(今天奈奈酱的治疗结束了...)",
      "playSE": "door_close"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(已经第2周了...奈奈酱好像习惯了)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(今天她还主动说\"请多关照\"...)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(那副毫无防备的样子...真让人受不了...)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(想尝试更大胆的治疗，但...可能还太早)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(但照这个速度，债务还款...)",
      "cutInImage": "debt_paper"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(为了实现色情按摩店的梦想而借的钱，但客人只有奈奈酱一个人...)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(不过，光是奈奈酱能来...就已经很开心了)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(她那纯真的反应...好想看到更多不同的表情...)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(债务的事...总会有办法的！)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(现在，这周必须做点什么...！)"
    }
  ]
}