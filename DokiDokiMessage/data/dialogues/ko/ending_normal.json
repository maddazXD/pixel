{
  "dialogues": [
    {
      "character": "",
      "hideCharacter": true,
      "text": "──반년 후.\n정체원은 지역에 뿌리내린 정체원으로 영업하고 있었다."
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "nana",
      "expression": "normal_happysmile",
      "text": "선생님, 안녕하세요. 이번 달도 잘 부탁드립니다.",
      "voiceFile": "ending_normal_001"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "나나, 어서 와. 컨디션은 어때?"
    },
    {
      "character": "nana",
      "expression": "normal_openmouth",
      "text": "요즘 또 어깨 결림이 심해서...",
      "voiceFile": "ending_normal_002"
    },
    {
      "character": "nana",
      "expression": "normal_smile_openmouth",
      "text": "역시 선생님의 시술이 제일 효과가 좋아요.",
      "voiceFile": "ending_normal_003"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(뭐, 이것도 나름 안정적인 관계인가...)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "그건 기쁘네. 오늘도 60분 코스로 할까?"
    },
    {
      "character": "nana",
      "expression": "normal_smile",
      "text": "네, 부탁드려요.",
      "voiceFile": "ending_normal_004"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "저... 그 특별한 옷도 입는 게 좋을까요?",
      "voiceFile": "ending_normal_005"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "응, 그걸 입으면 효과가 올라가거든."
    },
    {
      "character": "nana",
      "expression": "blush_nervoussmile",
      "text": "알겠어요. 처음엔 부끄러웠는데 이제는 익숙해졌어요...",
      "voiceFile": "ending_normal_006"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──시술 중"
    },
    {
      "character": "nana",
      "expression": "normal_happysmile",
      "text": "음... 기분 좋아요...",
      "voiceFile": "ending_normal_007"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "어깨 결림이 많이 풀렸네."
    },
    {
      "character": "nana",
      "expression": "normal_smile_openmouth",
      "text": "선생님 손은 정말 마법 같아요.",
      "voiceFile": "ending_normal_008"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(좀 더 공격적으로 갔어야 했나... 아니, 이 정도가 안전한가...)"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──시술 후"
    },
    {
      "character": "nana",
      "expression": "normal_happysmile",
      "text": "정말 편해졌어요. 감사합니다.",
      "voiceFile": "ending_normal_009"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "그렇다니 다행이야."
    },
    {
      "character": "nana",
      "expression": "normal_smile_openmouth",
      "text": "선생님, 다음 달 예약도 해도 될까요?",
      "voiceFile": "ending_normal_010"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "물론이지. 둘째 주 화요일로 할까?"
    },
    {
      "character": "nana",
      "expression": "normal_happysmile",
      "text": "네, 그날로 부탁드려요.",
      "voiceFile": "ending_normal_011"
    },
    {
      "character": "nana",
      "expression": "normal_smile_openmouth",
      "text": "선생님 덕분에 매달 컨디션이 좋아져요.",
      "voiceFile": "ending_normal_012"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "너 같은 단골손님이 있어줘서 정말 도움이 돼."
    },
    {
      "character": "nana",
      "expression": "normal_happysmile",
      "text": "그런... 저야말로 항상 신세를 지고 있어요.",
      "voiceFile": "ending_normal_013"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──몇 개월 후"
    },
    {
      "character": "nana",
      "expression": "normal_smile_openmouth",
      "text": "선생님, 요즘 가게가 붐비네요.",
      "voiceFile": "ending_normal_014"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "다행이지. 나나처럼 정기적으로 와주는 사람이 늘었거든."
    },
    {
      "character": "nana",
      "expression": "normal_smile_openmouth",
      "text": "잘됐네요. 선생님 실력이 좋으시니까요.",
      "voiceFile": "ending_normal_015"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "고마워. 그렇게 말해줘서 기뻐."
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(이것도 나름 좋은 관계인지도...)"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "적절한 거리를 유지하며 좋은 관계가 계속된다.\n그것도 행복의 한 형태일지도 모른다."
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "【NORMAL END - 좋은 고객 관계】",
      "triggerEnding": "normal"
    }
  ]
}
