{
  "dialogues": [
    {
      "character": "",
      "hideCharacter": true,
      "text": "──Tiga bulan kemudian. Klinik ini sudah mapan sebagai tempat yang sehat dan bermanfaat bagi komunitas."
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "nana",
      "expression": "normal_happysmile",
      "text": "Sensei, halo!",
      "voiceFile": "ending_trust_max_001"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Hei, Nana. Kamu datang lagi minggu ini."
    },
    {
      "character": "nana",
      "expression": "normal_smile",
      "text": "Iya. Aku datang untuk menemuimu, Sensei.",
      "voiceFile": "ending_trust_max_002"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Kamu tidak ada jadwal perawatan hari ini, kan?"
    },
    {
      "character": "nana",
      "expression": "blush_nervoussmile",
      "text": "...Iya. Ehehe... Aku cuma ingin mengobrol sebentar...",
      "voiceFile": "ending_trust_max_003"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Dia benar-benar sudah terbuka padaku...)"
    },
    {
      "character": "nana",
      "expression": "normal_openmouth",
      "text": "Um... ada sesuatu yang terjadi di sekolah...",
      "voiceFile": "ending_trust_max_004"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Uh-huh."
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "Nana dengan senang hati mulai bercerita tentang kehidupan sekolahnya belakangan ini."
    },
    {
      "character": "nana",
      "expression": "normal_smile_openmouth",
      "text": "Lalu, temanku...",
      "voiceFile": "ending_trust_max_005"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Oh, itu bagus."
    },
    {
      "character": "nana",
      "expression": "normal_closemouth",
      "text": "Juga... ada sesuatu yang menggangguku akhir-akhir ini...",
      "voiceFile": "ending_trust_max_006"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Hal seperti apa?"
    },
    {
      "character": "nana",
      "expression": "normal_closeeyes_closemouth",
      "text": "Hal-hal seperti jenjang karierku... dan masa depanku...",
      "voiceFile": "ending_trust_max_007"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Begitu ya. Ini memang masa di mana kamu memikirkan banyak hal."
    },
    {
      "character": "nana",
      "expression": "normal_openmouth",
      "text": "Aku tidak tahu harus bicara dengan siapa soal ini...",
      "voiceFile": "ending_trust_max_008"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Kalau denganku, aku selalu senang mendengarkan."
    },
    {
      "character": "nana",
      "expression": "normal_smile",
      "text": "...Terima kasih.",
      "voiceFile": "ending_trust_max_009"
    },
    {
      "character": "nana",
      "expression": "blush_nervoussmile",
      "text": "Sensei, kamu... rasanya seperti ayah...",
      "voiceFile": "ending_trust_max_010"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "A-ayah?"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "Ah, tidak... itu tidak sopan, ya. Um... seperti... kakak laki-laki...?",
      "voiceFile": "ending_trust_max_011"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Hahaha, yang mana saja boleh."
    },
    {
      "character": "nana",
      "expression": "normal_happysmile",
      "text": "Lagipula... kamu sangat bisa diandalkan.",
      "voiceFile": "ending_trust_max_012"
    },
    {
      "character": "nana",
      "expression": "normal_smile",
      "text": "Keberadaanmu saja... membuatku merasa tenang, kurasa...",
      "voiceFile": "ending_trust_max_013"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Aku senang mendengarnya."
    },
    {
      "character": "nana",
      "expression": "blush_happysmile",
      "text": "Iya. Karena ada Sensei di sini, aku jadi bisa berusaha semaksimal mungkin.",
      "voiceFile": "ending_trust_max_014"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Dia sudah tumbuh menjadi gadis yang luar biasa...)"
    },
    {
      "character": "nana",
      "expression": "normal_smile",
      "text": "Um... Sensei.",
      "voiceFile": "ending_trust_max_015"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Hm?"
    },
    {
      "character": "nana",
      "expression": "normal_happysmile",
      "text": "Aku... benar-benar senang bisa bertemu denganmu, Sensei.",
      "voiceFile": "ending_trust_max_016"
    },
    {
      "character": "nana",
      "expression": "blush_happysmile",
      "text": "Bukan cuma karena perawatannya... Sensei memperlakukanku dengan baik... seperti keluarga sendiri...",
      "voiceFile": "ending_trust_max_017"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Perasaan kita sama. Aku juga senang bisa bertemu denganmu, Nana."
    },
    {
      "character": "nana",
      "expression": "normal_happysmile",
      "text": "Mulai sekarang juga... tolong jaga aku terus, ya.",
      "voiceFile": "ending_trust_max_018"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "Tentu, begitu juga denganku."
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "Nana datang mengunjungi klinik bukan hanya untuk perawatan, tapi juga untuk berbagi kabar dan membicarakan kekhawatirannya."
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "Itu adalah ikatan layaknya keluarga, yang melampaui hubungan antara terapis dan pasien."
    },
    {
