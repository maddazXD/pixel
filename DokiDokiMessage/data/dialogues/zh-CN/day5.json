    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "这-这么说……有点害羞……",
      "voiceFile": "story_day5_016"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "抱歉抱歉。但这意味着你还能感受到更舒服的感觉。",
      "next": "change_clothes"
