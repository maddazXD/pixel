      ]
    },
    {
      "id": "serious_path",
      "character": "nana",
      "expression": "normal_openmouth",
      "text": "はい…自分でもちょっと姿勢が悪かったかもって思ってて…。",
      "voiceFile": "story_day2_009"
    },
    {
      "character": "player",
      "expression": "normal_closemouth",
      "text": "そういう小さな習慣の積み重ねが、身体に出るからね。",
      "next": "change_clothes"
    },
    {
      "id": "cute_butt_path",
      "character": "nana",
      "expression": "blush_surprised_sweat",
      "text": "か、かわいいって……っ！そ、そんなこと……急に言わないでください…っ",
      "voiceFile": "story_day2_010"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "ああ、ごめん。でも、本音が出ちゃっただけ。いい意味で言ったんだよ？",
      "next": "change_clothes"
    },
    {
      "id": "touch_path",
      "character": "nana",
      "expression": "blush_surprised_sweat",
      "text": "えっ……！？",
      "voiceFile": "story_day2_011",
      "cutInImage": "nana_butt_massage"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "うーん。なるほど……。",
      "cutInImage": "nana_butt_massage"
    },
    {
      "character": "nana",
      "expression": "blush_surprised_sweat",
      "text": "あ、あのっ……？",
      "voiceFile": "story_day2_012",
      "cutInImage": "nana_butt_massage"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "ここ大臀筋っていってね。身体の中でも一番大きな筋肉なんだ。",
      "cutInImage": "nana_butt_massage"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "座りっぱなしだと、この筋肉が固まって血流が悪くなるんだよ。",
      "cutInImage": "nana_butt_massage"
    },
    {
      "character": "nana",
      "expression": "blush_surprised_sweat",
      "text": "ひゃっ……！あ、あのっ……でも……！",
      "voiceFile": "story_day2_013",
      "cutInImage": "nana_butt_massage"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "腰痛の原因の多くは、実はお尻の筋肉が原因なんだ。ここをほぐさないと改善しにくいんだよ。",
      "cutInImage": "nana_butt_massage"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "そ、そうなんですか……知らなかったです……。",
      "voiceFile": "story_day2_014",
      "cutInImage": "nana_butt_massage"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "うん、かなり張ってるね。これじゃ脚のむくみも当然だよ。しっかりほぐしていこう。",
      "cutInImage": "nana_butt_massage"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "は、はい……確かに、さっきより身体がぽかぽかしてきました……。血流が良くなってるってことですか……？",
      "voiceFile": "story_day2_015",
      "next": "change_clothes"
