      }
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（かなり客が増えてきたな。忙しくて手が回らないくらいだ。売り上げも順調だな！）",
      "conditions": {
        "minCustomerCount": 30,
        "maxCustomerCount": 79
