    {
      "character": "nana",
      "expression": "ecstatic_openmouth",
      "text": "하아… 하아…♡",
      "voiceFile": "ending_develop_max_009"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "오늘도 많이 느꼈네."
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "저기……",
      "voiceFile": "ending_develop_max_010"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "응?"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "…답례로… 저도… 선생님한테 마사지… 해드려도 될까요…?",
      "voiceFile": "ending_develop_max_011"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "어? 나나가 나한테?"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "네, 네… 항상 기분 좋게 해주시니까…",
      "voiceFile": "ending_develop_max_012"
    },
    {
      "character": "nana",
      "expression": "blush_lookaway_openmouth",
      "text": "저도… 선생님을… 기분 좋게 해드리고 싶어서…",
      "voiceFile": "ending_develop_max_013"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "그렇구나. 그럼… 부탁해볼까."
    },
    {
      "character": "nana",
      "expression": "ecstatic_openmouth",
      "text": "네… 입으로… 선생님 것을… 마사지할게요…",
      "voiceFile": "ending_develop_max_014"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "어? 입으로?"
