    {
      "character": "nana",
      "expression": "blush_closeeyes_closemouth",
      "text": "…실례할게요…",
      "voiceFile": "ending_develop_max_016"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "나나는 살짝 떨리는 손으로 내 자지를 꺼냈다."
    },
    {
      "character": "nana",
      "expression": "ecstatic_openmouth",
      "text": "아… 벌써… 이렇게…♡",
      "voiceFile": "ending_develop_max_017"
    },
    {
      "character": "nana",
      "expression": "ecstatic_openmouth",
      "text": "…음…",
      "voiceFile": "ending_develop_max_018"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "응, 후우…. 할짝… 아무…… 쪽…♡ 할짝…… 응… 쪽…♡",
      "voiceFile": "ending_develop_max_019"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(이렇게 열심히 해주다니… 귀엽네…)"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "…푸하…♡",
      "voiceFile": "ending_develop_max_020"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "선생님… 어… 땠어요…?",
      "voiceFile": "ending_develop_max_021"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "정말 기분 좋았어. 나나, 고마워."
    },
    {
      "character": "nana",
      "expression": "blush_happysmile",
      "text": "다행이에요…",
      "voiceFile": "ending_develop_max_022"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "나나가 부끄러워하면서도 기대에 찬 눈으로 이쪽을 바라보고 있다."
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "저기… 선생님…",
      "voiceFile": "ending_develop_max_023"
