{
  "dialogues": [
    {
      "character": "",
      "hideCharacter": true,
      "text": "──11주차 아침.\n나나와 나 사이의 신뢰가 상당히 깊어졌다."
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(나나가 시술에 꽤 익숙해졌어...)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(최근 몸의 반응이 좋아졌어, 건강하다는 증거지)"
    },
    {
      "include": "common/weekly_settlement"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "nana",
      "expression": "blush_nervoussmile",
      "text": "안, 안녕하세요...",
      "voiceFile": "story_day11_001"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "오...? 오늘 벌써 젖어 있어?"
    },
    {
      "character": "nana",
      "expression": "blush_surprised_sweat",
      "text": "네!? 아, 아니에요...!",
      "voiceFile": "story_day11_002"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "걷는 모습으로 알 수 있어. 다리 꼬고 있잖아?"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "그, 그건... 그냥 몸이 안 좋아서...",
      "voiceFile": "story_day11_003"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "음... {{playerName}}씨... 상담할 게 있어요...",
      "voiceFile": "story_day11_004"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "뭔데?"
    },
    {
      "character": "nana",
      "expression": "blush_lookaway_openmouth",
      "text": "요즘 그냥 평범하게 생활하는데... 음... 너무 쉽게 젖어요...",
      "voiceFile": "story_day11_005"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "수업 시간에 의자에 앉기만 해도 아래가 근질근질...",
      "voiceFile": "story_day11_006"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "수업 시간에?"
    },
    {
      "character": "nana",
      "expression": "blush_lookaway_openmouth",
      "text": "의자가... 젖어요... 일어설 때 너무 부끄러워요...",
      "voiceFile": "story_day11_007"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "힘들겠네. 또 다른 건?"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "계단 오를 때도... 허벅지가 서로 부딪히면... 신음이 나올 뻔했어요...",
      "voiceFile": "story_day11_008"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "얼마 전에 친구가 어깨를 탁 쳤는데...",
      "voiceFile": "story_day11_009"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "어깨를 친 것만으로?"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "몸이 움찔했어요... \"괜찮아?\"라고 물어봐서...",
      "voiceFile": "story_day11_010"
    },
    {
      "character": "nana",
      "expression": "blush_lookaway_openmouth",
      "text": "화장실로 달려갔는데... 속옷이 이미 흠뻑 젖어 있었어요...",
      "voiceFile": "story_day11_011"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "(몸이 완전히 개발됐어... 좋아)"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "또, 전철에서도...",
      "voiceFile": "story_day11_012"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "전철에서도 뭔가 있어?"
    },
    {
      "character": "nana",
      "expression": "blush_lookaway_openmouth",
      "text": "손잡이를 꽉 잡아야 해요... 진동이... 견딜 수가 없어요...",
      "voiceFile": "story_day11_013"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "얼마 전에 전철이 급정거했을 때 몸이 흔들리면서...",
      "voiceFile": "story_day11_014"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "그러면서?"
    },
    {
      "character": "nana",
      "expression": "ecstatic_openmouth",
      "text": "이상한 소리가 나왔어요... 주변 사람들이 다 쳐다봤어요...",
      "voiceFile": "story_day11_015"
    },
    {
      "character": "nana",
      "expression": "ecstatic_openmouth",
      "text": "다음 역에서 내려서 역 화장실에 갔는데...",
      "voiceFile": "story_day11_016"
    },
    {
      "character": "nana",
      "expression": "blush_lookaway_openmouth",
      "text": "힘이 쭉 빠졌어요...",
      "voiceFile": "story_day11_017"
    },
    {
      "character": "player",
      "expression": "blush_closeeyes_closemouth",
      "text": "(역 화장실에서 절정을 맞이했다니... 너무 야해)"
    },
    {
      "id": "choice_massage11",
      "character": "player",
      "expression": "blush_closemouth",
      "text": "그렇구나. 오늘은 어떻게 할까?",
      "choices": [
        {
          "label": "감도를 조절하는 시술을 하자",
          "trustDelta": 2,
          "developDelta": 0,
          "next": "sensitivity_down_path"
        },
        {
          "label": "더 기분 좋아지는 연습을 하자",
          "trustDelta": 0,
          "developDelta": 2,
          "next": "practice_path"
        },
        {
          "label": "온몸을 성감대로 만들까",
          "trustDelta": 0,
          "developDelta": 3,
          "next": "full_body_path"
        }
      ]
    },
    {
      "id": "sensitivity_down_path",
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "감도를 낮춰주실 수 있나요...?",
      "voiceFile": "story_day11_018"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "물론! 특수 오일로 제대로 감도를 조절해 줄게."
    },
    {
      "character": "nana",
      "expression": "blush_happysmile",
      "text": "다행이에요... 그럼 안심이에요.",
      "next": "prepare_session",
      "voiceFile": "story_day11_019"
    },
    {
      "id": "practice_path",
      "character": "nana",
      "expression": "blush_surprised_sweat",
      "text": "연, 연습이요...?",
      "voiceFile": "story_day11_020"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "응! 조절하는 법을 익히면 문제없어!"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "하, 하지만... 부끄러워요...",
      "next": "prepare_session",
      "voiceFile": "story_day11_021"
    },
    {
      "id": "full_body_path",
      "character": "nana",
      "expression": "blush_surprised_sweat",
      "text": "온, 온몸을!?",
      "voiceFile": "story_day11_022"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "응! 머리카락 한 올만 만져도 경련하게!"
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "그, 그러면 더 심해지잖아요...!",
      "voiceFile": "story_day11_023"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "괜찮아! 평생 내가 돌봐줄 테니까.",
      "next": "prepare_session"
    },
    {
      "id": "prepare_session",
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "음... 또, 요즘 꿈을 잘 꿔요...",
      "voiceFile": "story_day11_024"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "그거 좋네."
    },
    {
      "character": "nana",
      "expression": "blush_nervoussmile",
      "text": "가끔 시술 받는 꿈을 꿔요...",
      "voiceFile": "story_day11_025"
    },
    {
      "character": "nana",
      "expression": "blush_nervoussmile",
      "text": "아침에 일어나면 몸이 정말 개운해요.",
      "voiceFile": "story_day11_026"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "시술이 효과 있다는 증거야."
    },
    {
      "character": "nana",
      "expression": "blush_nervoussmile",
      "text": "선생님 시술은 정말 효과가 있어요...",
      "voiceFile": "story_day11_027"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "그럼, 갈아입자."
    },
    {
      "character": "nana",
      "expression": "blush_closeeyes_closemouth",
      "text": "(이 옷도... 꽤 익숙해졌구나...)",
      "cutInImage": "nana_changing",
      "voiceFile": "story_day11_028"
    },
    {
      "character": "nana",
      "expression": "ecstatic_openmouth",
      "text": "갈, 갈아입었어요...",
      "outfit": "micro_bikini",
      "voiceFile": "story_day11_029"
    },
    {
      "character": "player",
      "expression": "ecstatic",
      "text": "준비됐어?"
    },
    {
      "character": "nana",
      "expression": "ecstatic_openmouth",
      "text": "네, 네... 부탁드려요.",
      "voiceFile": "story_day11_030"
    },
    {
      "id": "massage_start",
      "character": "player",
      "expression": "ecstatic",
      "text": "자, 오늘의 시술을 정성껏 진행할게."
    }
  ]
}
