    "talk_tired_parts": {
      "topicName": "疲劳部位",
      "trustEffect": 2,
      "developEffect": 0,
      "alertnessEffect": -1,
      "pleasureEffect": 0,
      "sleepinessEffect": 3,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "最近有哪里特别疲劳吗?"
