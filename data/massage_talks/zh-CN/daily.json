      "trustEffect": 1,
      "developEffect": 0,
      "alertnessEffect": -1,
      "pleasureEffect": 0,
      "sleepinessEffect": 1,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "今天又很热啊。来这里一定很辛苦吧?"
        },
        {
          "character": "Nana",
          "expression": "normal_02",
          "text": "是的...虽然撑着伞,但走路就开始出汗了...",
          "voiceFile": "talk_wether_001"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "我开了空调,慢慢放松吧。"
        },
        {
          "character": "Nana",
          "expression": "sleeping_02",
          "text": "...谢谢。好凉快,好舒服...",
          "voiceFile": "talk_wether_002"
        }
      ]
    },
    "talk_sleep": {
      "topicName": "睡眠习惯",
      "trustEffect": 2,
      "developEffect": 0,
      "alertnessEffect": -1,
      "pleasureEffect": 0,
      "sleepinessEffect": 4,
      "dialogues": [
        {
          "character": "player",
          "expression": "sleepy_01",
          "text": "睡觉的时候,你喜欢侧着睡还是仰着睡?"
        },
        {
          "character": "Nana",
          "expression": "sleepy_02",
          "text": "嗯...我经常侧着玩手机然后就睡着了...",
          "voiceFile": "talk_sleep_001"
        },
        {
          "character": "player",
          "expression": "sleepy_01",
          "text": "侧着玩手机对脖子不好哦。"
        },
        {
          "character": "player",
          "expression": "sleepy_01",
          "text": "试着仰着睡,在膝盖下垫个枕头,这样对腰部比较好。诀窍是睡前30分钟不要玩手机,把灯光调暗。"
        },
        {
          "character": "Nana",
          "expression": "sleepy_02",
          "text": "膝盖下垫枕头...我不知道这个。谢谢,我会试试的。",
          "voiceFile": "talk_sleep_002"
        }
      ]
    },
    "talk_hobby": {
