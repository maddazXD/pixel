      "trustEffect": 2,
      "developEffect": 0,
      "alertnessEffect": -2,
      "pleasureEffect": 0,
      "sleepinessEffect": 0,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "奈奈,你休息日都做些什么?"
