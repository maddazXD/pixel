      "developEffect": 0,
      "alertnessEffect": -5,
      "pleasureEffect": 0,
      "sleepinessEffect": 0,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "这是你第一次来按摩店吗?紧张吗?"
