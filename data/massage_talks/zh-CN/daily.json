        {
          "character": "player",
          "expression": "normal_01",
          "text": "是因为学习时长时间保持同一个姿势吗?"
        },
        {
          "character": "Nana",
          "expression": "normal_02",
          "text": "可能是吧...我在书桌前的时间很长...",
          "voiceFile": "talk_tired_parts_002"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "试着每小时站起来做做简单的伸展运动。今天我会好好帮你放松的。"
        },
        {
          "character": "Nana",
          "expression": "sleepy_02",
          "text": "谢谢...好舒服...",
          "voiceFile": "talk_tired_parts_003"
        }
      ]
    },
    "talk_school": {
      "topicName": "关于学校",
