    "talk_anime_secret": {
      "topicName": "秘密的动画爱好",
      "trustEffect": 4,
      "developEffect": 0,
      "alertnessEffect": -4,
      "pleasureEffect": 2,
      "sleepinessEffect": 1,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "你之前说过听动画歌曲。喜欢什么动画?"
        },
        {
          "character": "Nana",
          "expression": "alert_02",
          "text": "诶...你、你还记得啊...",
          "voiceFile": "talk_anime_secret_001"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "嗯。我很好奇。"
        },
        {
          "character": "Nana",
          "expression": "pleasure_02",
          "text": "...其实...周日早上有一部叫\"Lily Cure\"的动画,我...",
          "voiceFile": "talk_anime_secret_002"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "Lily Cure?就是那个女孩们变身的动画?"
        },
        {
          "character": "Nana",
          "expression": "alert_02",
          "text": "是、是的...很幼稚对吧...",
          "voiceFile": "talk_anime_secret_003"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "你看多久了?"
        },
        {
          "character": "Nana",
          "expression": "normal_02",
          "text": "从小学开始...一直在看。",
          "voiceFile": "talk_anime_secret_004"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "哇,看了这么久,一定很喜欢吧。"
        },
        {
          "character": "Nana",
          "expression": "sleepy_02",
          "text": "我跟朋友说的时候,她们觉得很奇怪...所以之后就没再告诉别人...",
          "voiceFile": "talk_anime_secret_005"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "我完全不觉得奇怪。喜欢就好。"
        },
        {
          "character": "Nana",
          "expression": "pleasure_02",
          "text": "真的吗...?谢谢...",
          "voiceFile": "talk_anime_secret_006"
        }
      ]
    },
    "talk_test_result": {
      "topicName": "考试成绩",
      "trustEffect": 3,
      "developEffect": 0,
      "alertnessEffect": -4,
      "pleasureEffect": 0,
      "sleepinessEffect": 3,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "你今天心情好像不错。发生什么好事了?"
        },
        {
          "character": "Nana",
