        {
          "character": "Nana",
          "expression": "alert_02",
          "text": "是一个被称为天才的男生...他总是第一。",
          "voiceFile": "talk_test_result_002"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "你也很厉害啊,奈奈。作为奖励,今天给你特别服务怎么样?"
