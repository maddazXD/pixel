        {
          "character": "Nana",
          "expression": "normal_02",
          "text": "特、特别服务...?",
          "voiceFile": "talk_test_result_003"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "想按摩哪里都可以!"
        },
        {
          "character": "Nana",
          "expression": "normal_02",
          "text": "哪里都可以...?",
          "voiceFile": "talk_test_result_004"
        },
        {
          "character": "Nana",
          "expression": "pleasure_02",
          "text": "那...嗯...",
          "voiceFile": "talk_test_result_005"
        },
        {
          "character": "Nana",
          "expression": "pleasure_02",
          "text": "可以...摸摸我的头吗...?",
          "voiceFile": "talk_test_result_006"
        },
        {
          "character": "player",
          "expression": "pleasure_01",
          "text": "!"
        },
        {
          "character": "player",
          "expression": "pleasure_01",
          "text": "当然!"
        }
      ]
    },
    "talk_travel_wish": {
      "topicName": "关于旅行",
      "trustEffect": 2,
      "developEffect": 0,
      "alertnessEffect": -2,
      "pleasureEffect": 0,
      "sleepinessEffect": 1,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "奈奈,你想去哪里旅行?"
        },
        {
          "character": "Nana",
          "expression": "normal_02",
          "text": "嗯...温泉吧...",
          "voiceFile": "talk_travel_wish_001"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "温泉!好成熟的选择啊。"
        },
        {
          "character": "Nana",
          "expression": "normal_02",
          "text": "奶奶很喜欢温泉,跟她一起去过之后就喜欢上了...",
          "voiceFile": "talk_travel_wish_002"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "温泉啊~不错啊。混浴吗?"
        },
        {
          "character": "Nana",
          "expression": "alert_02",
          "text": "不、不是!是普通的温泉!",
          "voiceFile": "talk_travel_wish_003"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "真可惜。如果是混浴的话,我就能和你一起泡了~"
        },
        {
          "character": "Nana",
          "expression": "alert_02",
          "text": "一起...?",
          "voiceFile": "talk_travel_wish_004"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "泡温泉皮肤会变得很滑呢。"
        },
        {
          "character": "Nana",
          "expression": "sleepy_02",
          "text": "是、是的...",
          "voiceFile": "talk_travel_wish_005"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "回来的时候要检查看看你的皮肤有没有变化!"
        }
      ]
    },
