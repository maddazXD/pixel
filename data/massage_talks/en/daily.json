      "developEffect": 0,
      "alertnessEffect": -2,
      "pleasureEffect": 0,
      "sleepinessEffect": 1,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "Ada tempat yang ingin kamu kunjungi untuk liburan, Nana?"
