      "pleasureEffect": 2,
      "sleepinessEffect": 1,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "Kamu sempat menyebutkan mendengarkan lagu anime tadi. Anime apa yang kamu suka?"
        },
        {
          "character": "Nana",
          "expression": "alert_02",
          "text": "Eh... K-kamu mengingatnya...",
          "voiceFile": "talk_anime_secret_001"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "Iya. Aku penasaran."
        },
        {
          "character": "Nana",
          "expression": "pleasure_02",
          "text": "...Sebenarnya... Ada anime di Minggu pagi berjudul 'Lily Cure' yang...",
          "voiceFile": "talk_anime_secret_002"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "Lily Cure? Yang gadis-gadisnya berubah wujud itu?"
        },
        {
          "character": "Nana",
          "expression": "alert_02",
          "text": "I-iya... Kedengarannya kekanak-kanakan, ya...",
          "voiceFile": "talk_anime_secret_003"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "Sudah berapa lama kamu menontonnya?"
        },
        {
          "character": "Nana",
          "expression": "normal_02",
          "text": "Sejak SD... Aku sudah menontonnya sejak saat itu.",
          "voiceFile": "talk_anime_secret_004"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "Wah, kalau kamu sudah menontonnya selama itu, berarti kamu benar-benar menyukainya."
        },
        {
          "character": "Nana",
          "expression": "sleepy_02",
          "text": "Waktu aku cerita ke teman-temanku, mereka pikir itu aneh... Jadi aku tidak pernah cerita ke siapa pun lagi sejak saat itu...",
          "voiceFile": "talk_anime_secret_005"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "Menurutku itu sama sekali tidak aneh. Kamu harus menyukai apa yang kamu sukai."
        },
        {
          "character": "Nana",
          "expression": "pleasure_02",
          "text": "Benarkah...? Terima kasih...",
          "voiceFile": "talk_anime_secret_006"
        }
      ]
    },
