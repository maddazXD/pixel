      "trustEffect": 1,
      "developEffect": 0,
      "alertnessEffect": -1,
      "pleasureEffect": 0,
      "sleepinessEffect": 1,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "Hari ini panas lagi ya. Pasti capek banget kan perjalanan ke sini?"
        },
        {
          "character": "Nana",
          "expression": "normal_02",
          "text": "Iya... Padahal sudah pakai payung, tapi aku tetap keringatan cuma gara-gara jalan kaki...",
          "voiceFile": "talk_wether_001"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "AC-nya sudah aku nyalakan, jadi santai saja dan istirahatlah dulu."
        },
        {
          "character": "Nana",
          "expression": "sleeping_02",
          "text": "...Terima kasih. Rasanya sejuk dan nyaman sekali...",
          "voiceFile": "talk_wether_002"
        }
      ]
    },
    "talk_sleep": {
